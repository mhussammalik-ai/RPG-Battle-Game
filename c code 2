int battle(Player *p, int map) {
    Enemy e = create_enemy(p, map);
    BattleRecord battleRecord;
    int initialHP = p->hp;
    int initialEXP = p->exp;
    int initialGold = p->gold;
    int playerDamageDealt = 0;
    int playerDamageTaken = 0;
    
    strcpy(battleRecord.enemyName, e.name);
    battleRecord.playerLevel = p->level;
    battleRecord.playerHP = initialHP;
    battleRecord.enemyHP = e.max_hp;
    battleRecord.isBoss = e.is_boss;
    battleRecord.isElite = e.is_elite;
    battleRecord.damageDealt = 0;
    battleRecord.damageTaken = 0;
    battleRecord.expGained = 0;
    battleRecord.goldGained = 0;
    
    while (p->hp > 0 && e.hp > 0) {
        print_header("BATTLE");
        
        printf("\nEnemy: %s\n", e.name);
        printf("HP: %d/%d", e.hp, e.max_hp);
        if (e.status != STATUS_NONE) printf(" [%s]", status_name(e.status));
        printf("\n");
        
        if (e.is_boss) {
            printf("BOSS BATTLE!\n");
        }
        if (e.is_elite) {
            printf("ELITE ENEMY!\n");
        }
        
        printf("\n");
        print_status(p);
        
        print_header("BATTLE MENU");
        printf("|  1. Attack                                     |\n");
        printf("|  2. Skill                                      |\n");
        printf("|  3. Item                                       |\n");
        printf("|  4. Flee                                       |\n");
        print_footer();
        printf("Choice: ");
        
        int choice = get_valid_input(1, 4);
        
        switch(choice) {
            case 1: {
                player_attack(p, &e);
                break;
            }
            case 2: {
                print_skills(p);
                printf("Choose skill (0 to cancel): ");
                int s = get_valid_input(0, p->skill_count);
                if (s > 0) {
                    player_use_skill(p, &e, s-1);
                }
                break;
            }
            case 3: {
                print_inventory(p);
                printf("Choose item (0 to cancel): ");
                int it = get_valid_input(0, p->item_count);
                if (it > 0) {
                    Item *item = &p->inventory[it-1];
                    if (item->quantity > 0) {
                        if (item->heal_amount > 0) {
                            p->hp += item->heal_amount;
                            if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
                            printf("Used %s, healed %d HP!\n", item->name, item->heal_amount);
                            item->quantity--;
                        } else if (item->restore_mp > 0) {
                            p->mp += item->restore_mp;
                            if (p->mp > total_max_mp(p)) p->mp = total_max_mp(p);
                            printf("Used %s, restored %d MP!\n", item->name, item->restore_mp);
                            item->quantity--;
                        }
                    } else {
                        printf("You don't have any %s left!\n", item->name);
                    }
                }
                break;
            }
            case 4: {
                printf("Attempting to flee...\n");
                int escape_chance = 30 + p->agility;
                if (r(0, 100) < escape_chance) {
                    printf("Fled successfully!\n");
                    strcpy(battleRecord.result, "FLEE");
                    battleRecord.damageDealt = playerDamageDealt;
                    battleRecord.damageTaken = playerDamageTaken;
                    battleRecord.expGained = 0;
                    battleRecord.goldGained = 0;
                    p->battleHistory[p->battleCount++] = battleRecord;
                    return 0;
                } else {
                    printf("Failed to flee! The enemy attacks!\n");
                }
                break;
            }
        }
        
        if (e.hp <= 0) {
            print_header("VICTORY!");
            printf("|  %s defeated!                                 |\n", e.name);
            print_footer();
            
            p->kills++;
            p->gold += e.gold_reward;
            p->total_gold_earned += e.gold_reward;
            
            if (e.is_boss) {
                p->bosses_defeated++;
                printf("BOSS DEFEATED! Amazing!\n");
                if (p->bosses_defeated >= 1) p->achievements[5] = 1;
                if (p->bosses_defeated >= 5) p->achievements[6] = 1;
                if (p->bosses_defeated >= 10) p->achievements[7] = 1;
            }
            
            gain_exp(p, e.exp_reward);
            printf("+%d gold\n", e.gold_reward);
            
            int drop_chance = e.is_boss ? 100 : (e.is_elite ? 60 : 25);
            if (r(0, 100) < drop_chance) {
                if (r(0, 100) < 50) {
                    add_item(p, "Health Potion", 1, 40, 0);
                    printf("Loot: Health Potion!\n");
                } else {
                    add_item(p, "Mana Potion", 1, 0, 30);
                    printf("Loot: Mana Potion!\n");
                }
            }
            
            int equip_drop_chance = e.is_boss ? 100 : (e.is_elite ? 45 : 8);
            if (r(0, 100) < equip_drop_chance) {
                Equipment eq = create_random_equipment(p->level, e.is_boss);
                equip_item(p, eq);
            }
            
            strcpy(battleRecord.result, "VICTORY");
            battleRecord.damageDealt = playerDamageDealt + (p->damage_dealt - playerDamageDealt);
            battleRecord.damageTaken = playerDamageTaken + (p->damage_taken - playerDamageTaken);
            battleRecord.expGained = e.exp_reward;
            battleRecord.goldGained = e.gold_reward;
            p->battleHistory[p->battleCount++] = battleRecord;
            
            show_anime_quote();
            printf("\nPress Enter to continue...");
            getchar();
            return 1;
        }
        
        if (!process_enemy_status(&e)) {
            enemy_attack(&e, p);
        }
        
        if (p->hp <= 0) {
            print_header("DEFEAT!");
            printf("|  %s has been defeated...                   |\n", p->name);
            print_footer();
            
            strcpy(battleRecord.result, "DEFEAT");
            battleRecord.damageDealt = playerDamageDealt;
            battleRecord.damageTaken = playerDamageTaken + (p->damage_taken - playerDamageTaken);
            battleRecord.expGained = 0;
            battleRecord.goldGained = 0;
            p->battleHistory[p->battleCount++] = battleRecord;
            
            printf("\nPress Enter to continue...");
            getchar();
            return -1;
        }
        
        printf("\nPress Enter to continue...");
        getchar();
    }
    return 0;
}

void save_game_slot(Player *p, int map, int slot) {
    if (slot < 1 || slot > MAX_SAVE_SLOTS) {
        printf("Invalid save slot!\n");
        return;
    }
    char filename[50];
    snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", slot);
    FILE *f = fopen(filename, "wb");
    if (!f) {
        printf("Failed to save game!\n");
        return;
    }
    fwrite(&map, sizeof(int), 1, f);
    fwrite(p, sizeof(Player), 1, f);
    fclose(f);
    printf("Game saved to slot %d!\n", slot);
}

int load_game_slot(Player *p, int *map, int slot) {
    if (slot < 1 || slot > MAX_SAVE_SLOTS) {
        printf("Invalid save slot!\n");
        return 0;
    }
    char filename[50];
    snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", slot);
    FILE *f = fopen(filename, "rb");
    if (!f) return 0;
    fread(map, sizeof(int), 1, f);
    fread(p, sizeof(Player), 1, f);
    fclose(f);
    return 1;
}

void list_save_slots(void) {
    print_header("SAVE SLOTS");
    for (int i = 1; i <= MAX_SAVE_SLOTS; i++) {
        char filename[50];
        snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", i);
        FILE *f = fopen(filename, "rb");
        if (f) {
            printf("|  Slot %d: SAVED                             |\n", i);
            fclose(f);
        } else {
            printf("|  Slot %d: EMPTY                             |\n", i);
        }
    }
    print_footer();
}

