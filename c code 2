Enemy create_enemy(Player *p, int map) {
    Enemy e;
    if (p->level % 5 == 0) {
        const char *bosses[] = {
            "Forest King Thornroot", "Skeleton King Xerath",
            "Shadow Emperor Nocturn", "Chaos Titan Zorath",
            "Dragon Lord Pyros", "Void Lich Malachar"
        };
        Element resist = ELEM_NONE;
        Element weakness = ELEM_NONE;
        int idx = (p->level / 5 - 1) % 6;
        if (idx < 0) idx = 0;
        
        switch(map) {
            case 1: resist = ELEM_NONE; weakness = ELEM_FIRE; break;
            case 2: resist = ELEM_ICE; weakness = ELEM_LIGHT; break;
            case 3: resist = ELEM_DARK; weakness = ELEM_LIGHT; break;
            case 4: resist = ELEM_FIRE; weakness = ELEM_ICE; break;
            case 5: resist = ELEM_LIGHTNING; weakness = ELEM_ICE; break;
            default: break;
        }
        
        init_enemy(&e, bosses[idx % 6],
                   200 + p->level * 35,
                   25 + p->level * 5,
                   10 + p->level * 2,
                   90 + p->level * 2,
                   150 + p->level * 3,
                   1, 0, resist, weakness);
        print_header("BOSS BATTLE!");
        printf("|  %s                                          |\n", e.name);
        print_footer();
    } else {
        const char *enemy_pools[5][4] = {
            {"Wolf", "Vine Stalker", "Forest Hunter", "Root Beast"},
            {"Skeleton Knight", "Cursed Armor", "Dark Prisoner", "Blood Warden"},
            {"Void Walker", "Shadow Reaper", "Nightmare", "Soul Devourer"},
            {"Flame Demon", "Chaos Beast", "Rift Walker", "Infernal Shade"},
            {"Young Dragon", "Drake", "Wyvern", "Dragon Knight"}
        };
        int pick = r(0, 3);
        int is_elite = (r(1, 100) <= 15);
        
        int hp = 60 + p->level * 12;
        int atk = 10 + p->level * 3;
        int def = 5 + p->level;
        int exp_r = 40 + p->level * 2;
        int gold_r = 50 + p->level * 3;
        
        if (is_elite) {
            hp = (int)(hp * 1.8);
            atk = (int)(atk * 1.4);
            def = (int)(def * 1.4);
            exp_r = (int)(exp_r * 2);
            gold_r = (int)(gold_r * 2);
        }
        
        Element resist = ELEM_NONE;
        Element weakness = ELEM_NONE;
        
        if (map == 2) resist = ELEM_ICE;
        else if (map == 3) resist = ELEM_DARK;
        else if (map == 4) resist = ELEM_FIRE;
        else if (map == 5) {
            resist = ELEM_LIGHTNING;
            weakness = ELEM_ICE;
        }
        
        init_enemy(&e, enemy_pools[map-1][pick], hp, atk, def, exp_r, gold_r,
                   0, is_elite, resist, weakness);
        
        if (is_elite) {
            print_header("ELITE ENEMY APPEARS!");
            printf("|  %s                                          |\n", e.name);
            print_footer();
        } else {
            print_header("ENEMY APPEARS!");
            printf("|  %s                                          |\n", e.name);
            print_footer();
        }
    }
    return e;
}

void apply_status_from_element(Enemy *e, Element elem) {
    if (r(1, 100) > 35) return;
    if (e->status != STATUS_NONE) return;
    
    switch(elem) {
        case ELEM_FIRE:
            if (e->resist != ELEM_FIRE) {
                e->status = STATUS_BURN;
                e->status_turns = 3;
                printf("%s is BURNING!\n", e->name);
            }
            break;
        case ELEM_ICE:
            if (e->resist != ELEM_ICE) {
                e->status = STATUS_FREEZE;
                e->status_turns = 2;
                printf("%s is FROZEN!\n", e->name);
            }
            break;
        case ELEM_LIGHTNING:
            if (e->resist != ELEM_LIGHTNING) {
                e->status = STATUS_STUN;
                e->status_turns = 1;
                printf("%s is STUNNED!\n", e->name);
            }
            break;
        case ELEM_DARK:
            if (e->resist != ELEM_DARK) {
                e->status = STATUS_CURSE;
                e->status_turns = 3;
                printf("%s is CURSED!\n", e->name);
            }
            break;
        case ELEM_WATER:
            if (e->resist != ELEM_WATER) {
                e->status = STATUS_POISON;
                e->status_turns = 3;
                printf("%s is POISONED!\n", e->name);
            }
            break;
        default: break;
    }
}

int process_enemy_status(Enemy *e) {
    if (e->status == STATUS_NONE) return 0;
    
    int skip_turn = 0;
    switch(e->status) {
        case STATUS_BURN:
            e->hp -= e->max_hp / 20;
            if (e->hp < 0) e->hp = 0;
            printf("%s takes BURN damage! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_POISON:
            e->hp -= e->max_hp / 15;
            if (e->hp < 0) e->hp = 0;
            printf("%s takes POISON damage! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_FREEZE:
            printf("%s is FROZEN and can't move!\n", e->name);
            skip_turn = 1;
            break;
        case STATUS_STUN:
            printf("%s is STUNNED and can't move!\n", e->name);
            skip_turn = 1;
            break;
        case STATUS_BLEED:
            e->hp -= e->max_hp / 25;
            if (e->hp < 0) e->hp = 0;
            printf("%s BLEEDS! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_CURSE:
            e->attack -= 5;
            printf("%s is CURSED! Attack reduced!\n", e->name);
            break;
        default: break;
    }
    
    e->status_turns--;
    if (e->status_turns <= 0) {
        if (e->status == STATUS_CURSE) e->attack += 5;
        e->status = STATUS_NONE;
        printf("%s recovered from status!\n", e->name);
    }
    return skip_turn;
}

int is_critical(Player *p) {
    return (r(1, 100) <= p->critical_rate + p->luck / 2);
}

int calc_damage(int attack, int defense) {
    int dmg = roll_damage(attack) - defense / 2;
    if (dmg < 1) dmg = 1;
    return dmg;
}

int try_dodge(Player *p) {
    return (r(1, 100) <= p->dodge_chance + p->agility / 3);
}

int try_block(Player *p) {
    return (r(1, 100) <= p->block_chance);
}

void player_attack(Player *p, Enemy *e) {
    int dmg = calc_damage(total_attack(p), e->defense);
    
    if (is_critical(p)) {
        dmg = dmg * p->critical_damage / 100;
        printf("CRITICAL HIT! ");
        p->combos++;
        if (p->combos > p->highest_combo) p->highest_combo = p->combos;
    } else {
        p->combos = 0;
    }
    
    if (e->weakness != ELEM_NONE) {
        printf("WEAKNESS EXPLOITED! ");
        dmg = (int)(dmg * 1.5);
    }
    
    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    
    printf("%s attacks %s for %d damage!\n", p->name, e->name, dmg);
    printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
}

void player_use_skill(Player *p, Enemy *e, int skill_index) {
    if (skill_index < 0 || skill_index >= p->skill_count) {
        printf("Invalid skill!\n");
        return;
    }
    Skill *s = &p->skills[skill_index];
    if (p->mp < s->mp_cost) {
        printf("Not enough MP! (Need %d)\n", s->mp_cost);
        return;
    }
    p->mp -= s->mp_cost;
    
    if (strcmp(s->name, "Heal") == 0) {
        int heal = s->power + p->intelligence * 2;
        p->hp += heal;
        if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
        printf("%s casts Heal and recovers %d HP! (HP: %d/%d)\n",
               p->name, heal, p->hp, total_max_hp(p));
        return;
    }
    
    if (strcmp(s->name, "War Cry") == 0) {
        p->attack += 5;
        printf("%s uses War Cry! Attack increased by 5!\n", p->name);
        return;
    }
    
    if (strcmp(s->name, "Holy Shield") == 0) {
        p->defense += 10;
        printf("%s uses Holy Shield! Defense increased by 10!\n", p->name);
        return;
    }
    
    if (strcmp(s->name, "Curse") == 0) {
        e->attack -= 5;
        printf("%s curses %s! Attack reduced!\n", p->name, e->name);
        return;
    }
    
    if (strcmp(s->name, "Summon Spirit") == 0) {
        int dmg = calc_damage(s->power + p->intelligence, e->defense);
        e->hp -= dmg;
        if (e->hp < 0) e->hp = 0;
        p->damage_dealt += dmg;
        printf("%s summons a spirit for %d damage!\n", p->name, dmg);
        printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
        return;
    }
    
    int base = s->power + p->intelligence * 2;
    int dmg = calc_damage(base, e->defense);
    
    if (e->weakness == s->element) {
        dmg = (int)(dmg * 1.5);
        printf("WEAKNESS EXPLOITED! ");
    }
    if (e->resist == s->element) {
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
        printf("%s resists %s! ", e->name, element_name(s->element));
    }
    
    if (is_critical(p)) {
        dmg = (int)(dmg * 1.5);
        printf("CRITICAL SKILL! ");
    }
    
    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    
    printf("%s casts %s for %d damage!\n", p->name, s->name, dmg);
    printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
    
    apply_status_from_element(e, s->element);
}

void enemy_attack(Enemy *e, Player *p) {
    if (try_dodge(p)) {
        printf("%s dodges the attack!\n", p->name);
        return;
    }
    
    int dmg = calc_damage(e->attack, total_defense(p));
    if (try_block(p)) {
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
        printf("%s blocks! Reduced damage.\n", p->name);
    }
    
    p->hp -= dmg;
    if (p->hp < 0) p->hp = 0;
    p->damage_taken += dmg;
    
    printf("%s hits %s for %d damage!\n", e->name, p->name, dmg);
    printf("%s HP: %d/%d\n", p->name, p->hp, total_max_hp(p));
}

Equipment create_random_equipment(int player_level, int is_boss) {
    Equipment eq;
    const char *weapon_names[] = {"Iron Sword", "Steel Blade", "Shadow Dagger", "Flame Brand", "Frost Edge"};
    const char *armor_names[] = {"Leather Armor", "Chain Mail", "Plate Armor", "Mithril Vest", "Dragon Scale"};
    const char *helmet_names[] = {"Leather Cap", "Iron Helm", "Knight's Helm", "Crown of Valor", "Dragon Helm"};
    const char *shield_names[] = {"Wooden Shield", "Iron Shield", "Kite Shield", "Tower Shield", "Aegis"};
    const char *ring_names[] = {"Copper Ring", "Silver Ring", "Gold Ring", "Platinum Ring", "Diamond Ring"};
    
    Rarity rarity;
    int roll = r(1, 100);
    if (is_boss) {
        if (roll <= 5) rarity = RARITY_MYTHIC;
        else if (roll <= 20) rarity = RARITY_LEGENDARY;
        else if (roll <= 45) rarity = RARITY_EPIC;
        else if (roll <= 70) rarity = RARITY_RARE;
        else if (roll <= 90) rarity = RARITY_UNCOMMON;
        else rarity = RARITY_COMMON;
    } else {
        if (roll <= 2) rarity = RARITY_LEGENDARY;
        else if (roll <= 8) rarity = RARITY_EPIC;
        else if (roll <= 20) rarity = RARITY_RARE;
        else if (roll <= 45) rarity = RARITY_UNCOMMON;
        else rarity = RARITY_COMMON;
    }
    
    EquipSlot slot = (EquipSlot)r(0, 4);
    eq.slot = slot;
    eq.rarity = rarity;
    
    int rarity_multiplier = 1;
    switch(rarity) {
        case RARITY_COMMON: rarity_multiplier = 1; break;
        case RARITY_UNCOMMON: rarity_multiplier = 2; break;
        case RARITY_RARE: rarity_multiplier = 3; break;
        case RARITY_EPIC: rarity_multiplier = 5; break;
        case RARITY_LEGENDARY: rarity_multiplier = 8; break;
        case RARITY_MYTHIC: rarity_multiplier = 12; break;
        default: rarity_multiplier = 1;
    }
    
    int base_bonus = player_level / 2 + 1;
    if (base_bonus < 1) base_bonus = 1;
    base_bonus *= rarity_multiplier;
    
    eq.atk_bonus = 0;
    eq.def_bonus = 0;
    eq.hp_bonus = 0;
    eq.mp_bonus = 0;
    
    switch(slot) {
        case SLOT_WEAPON:
            eq.atk_bonus = base_bonus + r(0, base_bonus/2);
            strncpy(eq.name, weapon_names[r(0, 4)], MAX_NAME - 1);
            break;
        case SLOT_ARMOR:
            eq.def_bonus = base_bonus + r(0, base_bonus/2);
            eq.hp_bonus = base_bonus;
            strncpy(eq.name, armor_names[r(0, 4)], MAX_NAME - 1);
            break;
        case SLOT_HELMET:
            eq.def_bonus = base_bonus/2 + r(0, base_bonus/2);
            eq.hp_bonus = base_bonus/2;
            strncpy(eq.name, helmet_names[r(0, 4)], MAX_NAME - 1);
            break;
        case SLOT_SHIELD:
            eq.def_bonus = base_bonus + r(0, base_bonus);
            strncpy(eq.name, shield_names[r(0, 4)], MAX_NAME - 1);
            break;
        case SLOT_RING:
            eq.atk_bonus = base_bonus/2;
            eq.def_bonus = base_bonus/2;
            eq.hp_bonus = base_bonus/2;
            eq.mp_bonus = base_bonus/2;
            strncpy(eq.name, ring_names[r(0, 4)], MAX_NAME - 1);
            break;
        default: break;
    }
    
    eq.name[MAX_NAME - 1] = '\0';
    return eq;
}

void equip_item(Player *p, Equipment eq) {
    print_header("EQUIPMENT DROP");
    printf("|  %s [%s]                                   |\n", eq.name, rarity_name(eq.rarity));
    print_separator();
    printf("|  Slot: %s                                     |\n", slot_name(eq.slot));
    printf("|  ATK+%d DEF+%d HP+%d MP+%d                   |\n", eq.atk_bonus, eq.def_bonus, eq.hp_bonus, eq.mp_bonus);
    print_footer();
    
    if (!p->has_equipment[eq.slot]) {
        p->equipment[eq.slot] = eq;
        p->has_equipment[eq.slot] = 1;
        printf("Equipped %s to %s slot!\n", eq.name, slot_name(eq.slot));
        return;
    }
    
    Equipment *current = &p->equipment[eq.slot];
    int new_score = eq.atk_bonus + eq.def_bonus + eq.hp_bonus + eq.mp_bonus;
    int old_score = current->atk_bonus + current->def_bonus + current->hp_bonus + current->mp_bonus;
    
    printf("Current: %s [%s] (Score: %d)\n", current->name, rarity_name(current->rarity), old_score);
    printf("New: %s [%s] (Score: %d)\n", eq.name, rarity_name(eq.rarity), new_score);
    
    if (new_score > old_score || eq.rarity > current->rarity) {
        printf("Better equipment found! Equipping new item.\n");
        p->equipment[eq.slot] = eq;
        p->has_equipment[eq.slot] = 1;
        printf("Equipped %s to %s slot!\n", eq.name, slot_name(eq.slot));
    } else {
        printf("Current equipment is better. %s discarded.\n", eq.name);
    }
}

