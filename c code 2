void add_skill(Player *p, const char *name, int power, int mp_cost, Element elem) {
    if (p->skill_count >= MAX_SKILLS) return;
    strncpy(p->skills[p->skill_count].name, name, MAX_NAME - 1);
    p->skills[p->skill_count].name[MAX_NAME - 1] = '\0';
    p->skills[p->skill_count].power = power;
    p->skills[p->skill_count].mp_cost = mp_cost;
    p->skills[p->skill_count].element = elem;
    p->skill_count++;
}

void add_item(Player *p, const char *name, int qty, int heal, int mp_restore) {
    for (int i = 0; i < p->item_count; i++) {
        if (strcmp(p->inventory[i].name, name) == 0 &&
            p->inventory[i].heal_amount == heal &&
            p->inventory[i].restore_mp == mp_restore) {
            p->inventory[i].quantity += qty;
            return;
        }
    }
    if (p->item_count >= MAX_INV) {
        printf("\nInventory full! Cannot add %s.\n", name);
        return;
    }
    strncpy(p->inventory[p->item_count].name, name, MAX_NAME - 1);
    p->inventory[p->item_count].name[MAX_NAME - 1] = '\0';
    p->inventory[p->item_count].quantity = qty;
    p->inventory[p->item_count].heal_amount = heal;
    p->inventory[p->item_count].restore_mp = mp_restore;
    p->item_count++;
}

void apply_class_bonuses(Player *p, ClassType cls) {
    p->cls = cls;
    switch(cls) {
        case CLASS_WARRIOR:
            p->max_hp += 60; p->attack += 10; p->defense += 8; 
            p->strength += 6; p->stamina += 4;
            add_skill(p, "Heavy Slash", 35, 8, ELEM_NONE);
            add_skill(p, "War Cry", 0, 5, ELEM_NONE);
            break;
        case CLASS_MAGE:
            p->max_mp += 50; p->intelligence += 8; 
            p->attack -= 2; p->critical_rate += 5;
            add_skill(p, "Fireball", 30, 10, ELEM_FIRE);
            add_skill(p, "Ice Shard", 35, 12, ELEM_ICE);
            add_skill(p, "Lightning Bolt", 40, 15, ELEM_LIGHTNING);
            break;
        case CLASS_ARCHER:
            p->agility += 8; p->luck += 4; p->attack += 5;
            p->critical_rate += 10; p->dodge_chance += 5;
            add_skill(p, "Piercing Arrow", 28, 9, ELEM_NONE);
            add_skill(p, "Multi Shot", 20, 12, ELEM_NONE);
            break;
        case CLASS_ASSASSIN:
            p->agility += 10; p->dodge_chance += 15; 
            p->attack += 4; p->critical_damage += 25;
            add_skill(p, "Shadow Strike", 35, 11, ELEM_DARK);
            add_skill(p, "Backstab", 45, 14, ELEM_NONE);
            break;
        case CLASS_PALADIN:
            p->defense += 10; p->max_hp += 40; p->block_chance += 10;
            p->strength += 3; p->intelligence += 3;
            add_skill(p, "Lightning Smite", 30, 10, ELEM_LIGHTNING);
            add_skill(p, "Holy Shield", 0, 8, ELEM_LIGHT);
            break;
        case CLASS_NECROMANCER:
            p->intelligence += 9; p->max_mp += 30;
            add_skill(p, "Dark Bolt", 32, 11, ELEM_DARK);
            add_skill(p, "Summon Spirit", 15, 15, ELEM_DARK);
            add_skill(p, "Curse", 0, 10, ELEM_DARK);
            break;
    }
    add_skill(p, "Heal", 30, 8, ELEM_NONE);
}

void init_player(Player *p, const char *name, ClassType cls) {
    strncpy(p->name, name, MAX_NAME - 1);
    p->name[MAX_NAME - 1] = '\0';
    p->level = 1;
    p->exp = 0;
    p->exp_to_next = 100;
    p->gold = 50;
    p->max_hp = 120;
    p->hp = p->max_hp;
    p->max_mp = 60;
    p->mp = p->max_mp;
    p->attack = 15;
    p->defense = 5;
    p->strength = 10;
    p->agility = 8;
    p->intelligence = 6;
    p->luck = 5;
    p->stamina = 8;
    p->critical_rate = 5;
    p->critical_damage = 150;
    p->dodge_chance = 5;
    p->block_chance = 5;
    p->skill_count = 0;
    p->item_count = 0;
    p->kills = 0;
    p->damage_dealt = 0;
    p->damage_taken = 0;
    p->bosses_defeated = 0;
    p->total_gold_earned = 0;
    p->combos = 0;
    p->highest_combo = 0;
    
    for (int i = 0; i < MAX_EQUIP; i++) p->has_equipment[i] = 0;
    for (int i = 0; i < 20; i++) p->achievements[i] = 0;
    
    apply_class_bonuses(p, cls);
    p->hp = total_max_hp(p);
    p->mp = total_max_mp(p);
    
    add_item(p, "Health Potion", 3, 40, 0);
    add_item(p, "Mana Potion", 2, 0, 30);
    add_item(p, "Bread", 2, 15, 0);
}

int total_attack(Player *p) {
    int atk = p->attack + p->strength * 2;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) atk += p->equipment[i].atk_bonus;
    }
    return atk;
}

int total_defense(Player *p) {
    int def = p->defense + p->stamina;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) def += p->equipment[i].def_bonus;
    }
    return def;
}

int total_max_hp(Player *p) {
    int hp = p->max_hp + p->stamina * 3;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) hp += p->equipment[i].hp_bonus;
    }
    return hp;
}

int total_max_mp(Player *p) {
    int mp = p->max_mp + p->intelligence * 2;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) mp += p->equipment[i].mp_bonus;
    }
    return mp;
}

void print_status(Player *p) {
    printf("\n========================================\n");
    printf("  ⚔️ %s the %s (Level %d)\n", p->name, class_name(p->cls), p->level);
    printf("========================================\n");
    printf(" HP: %d/%d    MP: %d/%d\n", p->hp, total_max_hp(p), p->mp, total_max_mp(p));
    printf(" ATK: %d      DEF: %d\n", total_attack(p), total_defense(p));
    printf(" Gold: %d     EXP: %d/%d\n", p->gold, p->exp, p->exp_to_next);
    printf(" Kills: %d    Bosses: %d\n", p->kills, p->bosses_defeated);
    printf("========================================\n");
}

void print_equipment(Player *p) {
    printf("\n========== EQUIPMENT ==========\n");
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) {
            printf("%s: %s [%s] (ATK+%d DEF+%d HP+%d)\n",
                   slot_name(i), p->equipment[i].name, 
                   rarity_name(p->equipment[i].rarity),
                   p->equipment[i].atk_bonus, p->equipment[i].def_bonus,
                   p->equipment[i].hp_bonus);
        } else {
            printf("%s: (empty)\n", slot_name(i));
        }
    }
    printf("================================\n");
}

void print_inventory(Player *p) {
    printf("\n========== INVENTORY ==========\n");
    if (p->item_count == 0) {
        printf("(empty)\n");
        return;
    }
    for (int i = 0; i < p->item_count; i++) {
        printf("%d) %s x%d", i+1, p->inventory[i].name, p->inventory[i].quantity);
        if (p->inventory[i].heal_amount > 0) 
            printf(" (Heal %d HP)", p->inventory[i].heal_amount);
        if (p->inventory[i].restore_mp > 0) 
            printf(" (Restore %d MP)", p->inventory[i].restore_mp);
        printf("\n");
    }
    printf("================================\n");
}

void print_skills(Player *p) {
    printf("\n========== SKILLS ==========\n");
    for (int i = 0; i < p->skill_count; i++) {
        printf("%d) %s", i+1, p->skills[i].name);
        if (p->skills[i].element != ELEM_NONE) 
            printf(" [%s]", element_name(p->skills[i].element));
        printf(" (Power:%d MP:%d)\n", p->skills[i].power, p->skills[i].mp_cost);
    }
    printf("=============================\n");
}

