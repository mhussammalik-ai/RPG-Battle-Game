#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define MAX_NAME 32
#define MAX_INV  20
#define MAX_SKILLS 5
#define MAX_EQUIP 5  /* Weapon, Armor, Helmet, Shield, Ring */

/* ================= ENUMS ================= */
typedef enum { CLASS_WARRIOR, CLASS_MAGE, CLASS_ARCHER, CLASS_ASSASSIN, CLASS_PALADIN, CLASS_NECROMANCER } ClassType;
typedef enum { RARITY_COMMON, RARITY_UNCOMMON, RARITY_RARE, RARITY_EPIC, RARITY_LEGENDARY, RARITY_MYTHIC } Rarity;
typedef enum { ELEM_NONE, ELEM_FIRE, ELEM_ICE, ELEM_LIGHTNING } Element;
typedef enum { STATUS_NONE, STATUS_BURN, STATUS_POISON, STATUS_FREEZE, STATUS_STUN } StatusEffect;
typedef enum { SLOT_WEAPON, SLOT_ARMOR, SLOT_HELMET, SLOT_SHIELD, SLOT_RING } EquipSlot;

/* ================= STRUCTS ================= */
typedef struct {
    char name[MAX_NAME];
    int power;
    int mp_cost;
    Element element;
} Skill;

typedef struct {
    char name[MAX_NAME];
    int quantity;
    int heal_amount;
} Item;

typedef struct {
    char name[MAX_NAME];
    EquipSlot slot;
    Rarity rarity;
    int atk_bonus;
    int def_bonus;
    int hp_bonus;
    int mp_bonus;
    int equipped; /* 1 if currently worn */
} Equipment;

typedef struct {
    char name[MAX_NAME];
    ClassType cls;
    int level;
    int exp;
    int exp_to_next;
    int gold;
    int hp, max_hp;
    int mp, max_mp;
    int attack;
    int defense;
    int strength;
    int agility;
    int intelligence;
    int luck;
    Skill skills[MAX_SKILLS];
    int skill_count;
    Item inventory[MAX_INV];
    int item_count;
    Equipment equipment[MAX_EQUIP]; /* index = slot */
    int has_equipment[MAX_EQUIP];   /* 1 if slot occupied */
    int kills;
    int damage_dealt;
    int damage_taken;
    int dodge_chance;   /* base % */
    int block_chance;   /* base % */
} Player;

typedef struct {
    char name[MAX_NAME];
    int hp, max_hp;
    int attack;
    int defense;
    int exp_reward;
    int gold_reward;
    int is_boss;
    int is_elite;
    Element resist; /* element this enemy resists */
    StatusEffect status;
    int status_turns;
} Enemy;

/* ================= RANDOM ================= */
int r(int a, int b) {
    return a + rand() % (b - a + 1);
}
int roll_damage(int base) {
    int variance = base / 4;
    if (variance < 1) variance = 1;
    return base + (rand() % (2 * variance + 1)) - variance;
}

