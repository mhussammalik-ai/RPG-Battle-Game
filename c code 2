Enemy create_enemy(Player *p, int map) {
    Enemy e;
    if (p->level % 5 == 0) {
        const char *bosses[] = {
            "Forest King Thornroot", "Skeleton King Xerath",
            "Shadow Emperor Nocturn", "Chaos Titan Zorath",
            "Dragon Lord Pyros", "Void Lich Malachar"
        };
        Element resist = ELEM_NONE;
        Element weakness = ELEM_NONE;
        int idx = (p->level / 5 - 1) % 6;
        if (idx < 0) idx = 0;
        
        switch(map) {
            case 1: resist = ELEM_NONE; weakness = ELEM_FIRE; break;
            case 2: resist = ELEM_ICE; weakness = ELEM_LIGHT; break;
            case 3: resist = ELEM_DARK; weakness = ELEM_LIGHT; break;
            case 4: resist = ELEM_FIRE; weakness = ELEM_ICE; break;
            case 5: resist = ELEM_LIGHTNING; weakness = ELEM_ICE; break;
            default: break;
        }
        
        init_enemy(&e, bosses[idx % 6],
                   200 + p->level * 35,
                   25 + p->level * 5,
                   10 + p->level * 2,
                   90 + p->level * 2,
                   150 + p->level * 3,
                   1, 0, resist, weakness);
        printf("\n========================================\n");
        printf("     👑 BOSS BATTLE: %s 👑\n", e.name);
        printf("========================================\n");
    } else {
        const char *enemy_pools[5][4] = {
            {"Wolf", "Vine Stalker", "Forest Hunter", "Root Beast"},
            {"Skeleton Knight", "Cursed Armor", "Dark Prisoner", "Blood Warden"},
            {"Void Walker", "Shadow Reaper", "Nightmare", "Soul Devourer"},
            {"Flame Demon", "Chaos Beast", "Rift Walker", "Infernal Shade"},
            {"Young Dragon", "Drake", "Wyvern", "Dragon Knight"}
        };
        int pick = r(0, 3);
        int is_elite = (r(1, 100) <= 15);
        
        int hp = 60 + p->level * 12;
        int atk = 10 + p->level * 3;
        int def = 5 + p->level;
        int exp_r = 40 + p->level * 2;
        int gold_r = 50 + p->level * 3;
        
        if (is_elite) {
            hp = (int)(hp * 1.8);
            atk = (int)(atk * 1.4);
            def = (int)(def * 1.4);
            exp_r = (int)(exp_r * 2);
            gold_r = (int)(gold_r * 2);
        }
        
        Element resist = ELEM_NONE;
        Element weakness = ELEM_NONE;
        
        if (map == 2) resist = ELEM_ICE;
        else if (map == 3) resist = ELEM_DARK;
        else if (map == 4) resist = ELEM_FIRE;
        else if (map == 5) {
            resist = ELEM_LIGHTNING;
            weakness = ELEM_ICE;
        }
        
        init_enemy(&e, enemy_pools[map-1][pick], hp, atk, def, exp_r, gold_r,
                   0, is_elite, resist, weakness);
        
        if (is_elite) {
            printf("\n========================================\n");
            printf("     ⚡ ELITE: %s appears! ⚡\n", e.name);
            printf("========================================\n");
        } else {
            printf("\n========================================\n");
            printf("     %s appears!\n", e.name);
            printf("========================================\n");
        }
    }
    return e;
}

void apply_status_from_element(Enemy *e, Element elem) {
    if (r(1, 100) > 35) return;
    if (e->status != STATUS_NONE) return;
    
    switch(elem) {
        case ELEM_FIRE:
            if (e->resist != ELEM_FIRE) {
                e->status = STATUS_BURN;
                e->status_turns = 3;
                printf("🔥 %s is BURNING!\n", e->name);
            }
            break;
        case ELEM_ICE:
            if (e->resist != ELEM_ICE) {
                e->status = STATUS_FREEZE;
                e->status_turns = 2;
                printf("❄️ %s is FROZEN!\n", e->name);
            }
            break;
        case ELEM_LIGHTNING:
            if (e->resist != ELEM_LIGHTNING) {
                e->status = STATUS_STUN;
                e->status_turns = 1;
                printf("⚡ %s is STUNNED!\n", e->name);
            }
            break;
        case ELEM_DARK:
            if (e->resist != ELEM_DARK) {
                e->status = STATUS_CURSE;
                e->status_turns = 3;
                printf("🌑 %s is CURSED!\n", e->name);
            }
            break;
        case ELEM_WATER:
            if (e->resist != ELEM_WATER) {
                e->status = STATUS_POISON;
                e->status_turns = 3;
                printf("💀 %s is POISONED!\n", e->name);
            }
            break;
        default: break;
    }
}

int process_enemy_status(Enemy *e) {
    if (e->status == STATUS_NONE) return 0;
    
    int skip_turn = 0;
    switch(e->status) {
        case STATUS_BURN:
            e->hp -= e->max_hp / 20;
            if (e->hp < 0) e->hp = 0;
            printf("🔥 %s takes BURN damage! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_POISON:
            e->hp -= e->max_hp / 15;
            if (e->hp < 0) e->hp = 0;
            printf("💀 %s takes POISON damage! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_FREEZE:
            printf("❄️ %s is FROZEN and can't move!\n", e->name);
            skip_turn = 1;
            break;
        case STATUS_STUN:
            printf("⚡ %s is STUNNED and can't move!\n", e->name);
            skip_turn = 1;
            break;
        case STATUS_BLEED:
            e->hp -= e->max_hp / 25;
            if (e->hp < 0) e->hp = 0;
            printf("🩸 %s BLEEDS! (HP: %d/%d)\n", e->name, e->hp, e->max_hp);
            break;
        case STATUS_CURSE:
            e->attack -= 5;
            printf("🌑 %s is CURSED! Attack reduced!\n", e->name);
            break;
        default: break;
    }
    
    e->status_turns--;
    if (e->status_turns <= 0) {
        if (e->status == STATUS_CURSE) e->attack += 5;
        e->status = STATUS_NONE;
        printf("%s recovered from status!\n", e->name);
    }
    return skip_turn;
}

/* ================= COMBAT IMPLEMENTATIONS ================= */
int is_critical(Player *p) {
    return (r(1, 100) <= p->critical_rate + p->luck / 2);
}

int calc_damage(int attack, int defense) {
    int dmg = roll_damage(attack) - defense / 2;
    if (dmg < 1) dmg = 1;
    return dmg;
}

int try_dodge(Player *p) {
    return (r(1, 100) <= p->dodge_chance + p->agility / 3);
}

int try_block(Player *p) {
    return (r(1, 100) <= p->block_chance);
}

void player_attack(Player *p, Enemy *e) {
    int dmg = calc_damage(total_attack(p), e->defense);
    
    if (is_critical(p)) {
        dmg = dmg * p->critical_damage / 100;
        printf("💥 CRITICAL HIT! ");
        p->combos++;
        if (p->combos > p->highest_combo) p->highest_combo = p->combos;
    } else {
        p->combos = 0;
    }
    
    if (e->weakness != ELEM_NONE) {
        printf("🎯 WEAKNESS EXPLOITED! ");
        dmg = (int)(dmg * 1.5);
    }
    
    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    
    printf("%s attacks %s for %d damage!\n", p->name, e->name, dmg);
    printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
}

void player_use_skill(Player *p, Enemy *e, int skill_index) {
    if (skill_index < 0 || skill_index >= p->skill_count) {
        printf("Invalid skill!\n");
        return;
    }
    Skill *s = &p->skills[skill_index];
    if (p->mp < s->mp_cost) {
        printf("Not enough MP! (Need %d)\n", s->mp_cost);
        return;
    }
    p->mp -= s->mp_cost;
    
    if (strcmp(s->name, "Heal") == 0) {
        int heal = s->power + p->intelligence * 2;
        p->hp += heal;
        if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
        printf("💚 %s casts Heal and recovers %d HP! (HP: %d/%d)\n",
               p->name, heal, p->hp, total_max_hp(p));
        return;
    }
    
    if (strcmp(s->name, "War Cry") == 0) {
        p->attack += 5;
        printf("🗡️ %s uses War Cry! Attack increased by 5!\n", p->name);
        return;
    }
    
    if (strcmp(s->name, "Holy Shield") == 0) {
        p->defense += 10;
        printf("🛡️ %s uses Holy Shield! Defense increased by 10!\n", p->name);
        return;
    }
    
    if (strcmp(s->name, "Curse") == 0) {
        e->attack -= 5;
        printf("🌑 %s curses %s! Attack reduced!\n", p->name, e->name);
        return;
    }
    
    if (strcmp(s->name, "Summon Spirit") == 0) {
        int dmg = calc_damage(s->power + p->intelligence, e->defense);
        e->hp -= dmg;
        if (e->hp < 0) e->hp = 0;
        p->damage_dealt += dmg;
        printf("👻 %s summons a spirit for %d damage!\n", p->name, dmg);
        printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
        return;
    }
    
    int base = s->power + p->intelligence * 2;
    int dmg = calc_damage(base, e->defense);
    
    if (e->weakness == s->element) {
        dmg = (int)(dmg * 1.5);
        printf("🎯 WEAKNESS EXPLOITED! ");
    }
    if (e->resist == s->element) {
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
        printf("🛡️ %s resists %s! ", e->name, element_name(s->element));
    }
    
    if (is_critical(p)) {
        dmg = (int)(dmg * 1.5);
        printf("💥 CRITICAL SKILL! ");
    }
    
    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    
    printf("✨ %s casts %s for %d damage!\n", p->name, s->name, dmg);
    printf("%s HP: %d/%d\n", e->name, e->hp, e->max_hp);
    
    apply_status_from_element(e, s->element);
}

void enemy_attack(Enemy *e, Player *p) {
    if (try_dodge(p)) {
        printf("💨 %s dodges the attack!\n", p->name);
        return;
    }
    
    int dmg = calc_damage(e->attack, total_defense(p));
    if (try_block(p)) {
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
        printf("🛡️ %s blocks! Reduced damage.\n", p->name);
    }
    
    p->hp -= dmg;
    if (p->hp < 0) p->hp = 0;
    p->damage_taken += dmg;
    
    printf("💢 %s hits %s for %d damage!\n", e->name, p->name, dmg);
    printf("%s HP: %d/%d\n", p->name, p->hp, total_max_hp(p));
}

int battle(Player *p, int map) {
    Enemy e = create_enemy(p, map);
    
    while (p->hp > 0 && e.hp > 0) {
        printf("\n========================================\n");
        printf("             ⚔️ BATTLE ⚔️\n");
        printf("========================================\n");
        
        printf("\n%s\n", e.name);
        printf("HP: %d/%d", e.hp, e.max_hp);
        if (e.status != STATUS_NONE) printf(" [%s]", status_name(e.status));
        printf("\n");
        
        if (e.is_boss) {
            printf("*** 👑 BOSS BATTLE! 👑 ***\n");
        }
        
        printf("\n");
        print_status(p);
        
        printf("\n========================================\n");
        printf(" 1. ⚔️ Attack\n");
        printf(" 2. ✨ Skill\n");
        printf(" 3. 🧪 Item\n");
        printf(" 4. 🏃 Flee\n");
        printf("========================================\n");
        printf("Choice: ");
        
        int choice = get_valid_input(1, 4);
        
        switch(choice) {
            case 1:
                player_attack(p, &e);
                break;
            case 2:
                print_skills(p);
                printf("Choose skill (0 to cancel): ");
                int s = get_valid_input(0, p->skill_count);
                if (s > 0) {
                    player_use_skill(p, &e, s-1);
                }
                break;
            case 3:
                print_inventory(p);
                printf("Choose item (0 to cancel): ");
                int it = get_valid_input(0, p->item_count);
                if (it > 0) {
                    Item *item = &p->inventory[it-1];
                    if (item->quantity > 0) {
                        if (item->heal_amount > 0) {
                            p->hp += item->heal_amount;
                            if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
                            printf("💚 Used %s, healed %d HP!\n", item->name, item->heal_amount);
                            item->quantity--;
                        } else if (item->restore_mp > 0) {
                            p->mp += item->restore_mp;
                            if (p->mp > total_max_mp(p)) p->mp = total_max_mp(p);
                            printf("💙 Used %s, restored %d MP!\n", item->name, item->restore_mp);
                            item->quantity--;
                        }
                    } else {
                        printf("You don't have any %s left!\n", item->name);
                    }
                }
                break;
            case 4:
                printf("Attempting to flee...\n");
                int escape_chance = 30 + p->agility;
                if (r(0, 100) < escape_chance) {
                    printf("🏃 Fled successfully!\n");
                    return 0;
                } else {
                    printf("Failed to flee! The enemy attacks!\n");
                }
                break;
        }
        
        if (e.hp <= 0) {
            printf("\n========================================\n");
            printf("     🎉 VICTORY! %s defeated! 🎉\n", e.name);
            printf("========================================\n");
            
            p->kills++;
            p->gold += e.gold_reward;
            p->total_gold_earned += e.gold_reward;
            
            if (e.is_boss) {
                p->bosses_defeated++;
                printf("👑 BOSS DEFEATED! Amazing!\n");
                if (p->bosses_defeated >= 1) p->achievements[5] = 1;
                if (p->bosses_defeated >= 5) p->achievements[6] = 1;
                if (p->bosses_defeated >= 10) p->achievements[7] = 1;
            }
            
            gain_exp(p, e.exp_reward);
            printf("💰 +%d gold\n", e.gold_reward);
            
            int drop_chance = e.is_boss ? 100 : (e.is_elite ? 60 : 25);
            if (r(0, 100) < drop_chance) {
                if (r(0, 100) < 50) {
                    add_item(p, "Health Potion", 1, 40, 0);
                    printf("🎁 Loot: Health Potion!\n");
                } else {
                    add_item(p, "Mana Potion", 1, 0, 30);
                    printf("🎁 Loot: Mana Potion!\n");
                }
            }
            
            show_anime_quote();
            printf("\nPress Enter to continue...");
            getchar();
            return 1;
        }
        
        // Enemy turn
        if (!process_enemy_status(&e)) {
            enemy_attack(&e, p);
        }
        
        if (p->hp <= 0) {
            printf("\n========================================\n");
            printf("     💀 %s has been defeated... 💀\n", p->name);
            printf("========================================\n");
            printf("\nPress Enter to continue...");
            getchar();
            return -1;
        }
        
        printf("\nPress Enter to continue...");
        getchar();
    }
    return 0;
}

/* ================= SAVE/LOAD IMPLEMENTATIONS ================= */
void save_game_slot(Player *p, int map, int slot) {
    if (slot < 1 || slot > MAX_SAVE_SLOTS) {
        printf("Invalid save slot!\n");
        return;
    }
    char filename[50];
    snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", slot);
    FILE *f = fopen(filename, "wb");
    if (!f) {
        printf("Failed to save game!\n");
        return;
    }
    fwrite(&map, sizeof(int), 1, f);
    fwrite(p, sizeof(Player), 1, f);
    fclose(f);
    printf("💾 Game saved to slot %d!\n", slot);
}

int load_game_slot(Player *p, int *map, int slot) {
    if (slot < 1 || slot > MAX_SAVE_SLOTS) {
        printf("Invalid save slot!\n");
        return 0;
    }
    char filename[50];
    snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", slot);
    FILE *f = fopen(filename, "rb");
    if (!f) return 0;
    fread(map, sizeof(int), 1, f);
    fread(p, sizeof(Player), 1, f);
    fclose(f);
    return 1;
}

void list_save_slots(void) {
    printf("\n========== SAVE SLOTS ==========\n");
    for (int i = 1; i <= MAX_SAVE_SLOTS; i++) {
        char filename[50];
        snprintf(filename, sizeof(filename), "starzilla_save_%d.dat", i);
        FILE *f = fopen(filename, "rb");
        if (f) {
            printf("Slot %d: 💾 SAVED\n", i);
            fclose(f);
        } else {
            printf("Slot %d: 📭 EMPTY\n", i);
        }
    }
    printf("================================\n");
}

