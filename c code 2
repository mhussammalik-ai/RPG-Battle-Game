/* ================= RARITY HELPERS ================= */
const char* rarity_name(Rarity r) {
    switch (r) {
        case RARITY_COMMON: return "Common";
        case RARITY_UNCOMMON: return "Uncommon";
        case RARITY_RARE: return "Rare";
        case RARITY_EPIC: return "Epic";
        case RARITY_LEGENDARY: return "Legendary";
        case RARITY_MYTHIC: return "Mythic";
        default: return "Unknown";
    }
}
const char* slot_name(EquipSlot s) {
    switch (s) {
        case SLOT_WEAPON: return "Weapon";
        case SLOT_ARMOR: return "Armor";
        case SLOT_HELMET: return "Helmet";
        case SLOT_SHIELD: return "Shield";
        case SLOT_RING: return "Ring";
        default: return "Unknown";
    }
}
const char* element_name(Element e) {
    switch (e) {
        case ELEM_FIRE: return "Fire";
        case ELEM_ICE: return "Ice";
        case ELEM_LIGHTNING: return "Lightning";
        default: return "None";
    }
}
const char* status_name(StatusEffect s) {
    switch (s) {
        case STATUS_BURN: return "Burn";
        case STATUS_POISON: return "Poison";
        case STATUS_FREEZE: return "Freeze";
        case STATUS_STUN: return "Stun";
        default: return "None";
    }
}
/* Rarity multiplier for stat bonuses */
int rarity_multiplier(Rarity r) {
    switch (r) {
        case RARITY_COMMON: return 1;
        case RARITY_UNCOMMON: return 2;
        case RARITY_RARE: return 3;
        case RARITY_EPIC: return 5;
        case RARITY_LEGENDARY: return 8;
        case RARITY_MYTHIC: return 12;
        default: return 1;
    }
}

/* ================= PLAYER ================= */
void add_skill(Player *p, const char *name, int power, int mp_cost, Element elem) {
    if (p->skill_count >= MAX_SKILLS) return;
    strncpy(p->skills[p->skill_count].name, name, MAX_NAME - 1);
    p->skills[p->skill_count].name[MAX_NAME - 1] = '\0';
    p->skills[p->skill_count].power = power;
    p->skills[p->skill_count].mp_cost = mp_cost;
    p->skills[p->skill_count].element = elem;
    p->skill_count++;
}

void add_item(Player *p, const char *name, int qty, int heal) {
    /* If item already exists, stack it */
    for (int i = 0; i < p->item_count; i++) {
        if (strcmp(p->inventory[i].name, name) == 0) {
            p->inventory[i].quantity += qty;
            return;
        }
    }
    if (p->item_count >= MAX_INV) return;
    strncpy(p->inventory[p->item_count].name, name, MAX_NAME - 1);
    p->inventory[p->item_count].name[MAX_NAME - 1] = '\0';
    p->inventory[p->item_count].quantity = qty;
    p->inventory[p->item_count].heal_amount = heal;
    p->item_count++;
}

/* Apply class-based starting stats and skills */
void apply_class_bonuses(Player *p, ClassType cls) {
    p->cls = cls;
    switch (cls) {
        case CLASS_WARRIOR:
            p->max_hp += 40; p->attack += 8; p->defense += 5; p->strength += 4;
            add_skill(p, "Heavy Slash", 30, 8, ELEM_NONE);
            break;
        case CLASS_MAGE:
            p->max_mp += 40; p->intelligence += 6; p->attack -= 3;
            add_skill(p, "Fireball", 25, 10, ELEM_FIRE);
            add_skill(p, "Ice Shard", 28, 12, ELEM_ICE);
            break;
        case CLASS_ARCHER:
            p->agility += 6; p->luck += 3; p->attack += 4;
            add_skill(p, "Piercing Arrow", 26, 9, ELEM_NONE);
            break;
        case CLASS_ASSASSIN:
            p->agility += 8; p->dodge_chance += 10; p->attack += 3;
            add_skill(p, "Shadow Strike", 32, 11, ELEM_NONE);
            break;
        case CLASS_PALADIN:
            p->defense += 8; p->max_hp += 30; p->block_chance += 10;
            add_skill(p, "Lightning Smite", 27, 10, ELEM_LIGHTNING);
            break;
        case CLASS_NECROMANCER:
            p->intelligence += 7; p->max_mp += 25;
            add_skill(p, "Dark Bolt", 30, 11, ELEM_NONE);
            break;
    }
    /* Heal is universal */
    add_skill(p, "Heal", 30, 8, ELEM_NONE);
}

void init_player(Player *p, const char *name, ClassType cls) {
    strncpy(p->name, name, MAX_NAME - 1);
    p->name[MAX_NAME - 1] = '\0';
    p->level = 1;
    p->exp = 0;
    p->exp_to_next = 100;
    p->gold = 50;
    p->max_hp = 120;
    p->hp = p->max_hp;
    p->max_mp = 60;
    p->mp = p->max_mp;
    p->attack = 15;
    p->defense = 5;
    p->strength = 10;
    p->agility = 8;
    p->intelligence = 6;
    p->luck = 5;
    p->skill_count = 0;
    p->item_count = 0;
    p->kills = 0;
    p->damage_dealt = 0;
    p->damage_taken = 0;
    p->dodge_chance = 5;  /* base dodge */
    p->block_chance = 5;  /* base block */
    for (int i = 0; i < MAX_EQUIP; i++) p->has_equipment[i] = 0;

    apply_class_bonuses(p, cls);

    /* Re-apply full heal since bonuses may have changed max stats */
    p->hp = p->max_hp;
    p->mp = p->max_mp;

    add_item(p, "Health Potion", 3, 40);
    add_item(p, "Mana Potion", 2, 0); /* heal_amount=0 means restores MP, handled specially */
}

/* Compute total attack/defense including equipment bonuses */
int total_attack(Player *p) {
    int atk = p->attack + p->strength;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) atk += p->equipment[i].atk_bonus;
    }
    return atk;
}
int total_defense(Player *p) {
    int def = p->defense;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) def += p->equipment[i].def_bonus;
    }
    return def;
}
int total_max_hp(Player *p) {
    int hp = p->max_hp;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) hp += p->equipment[i].hp_bonus;
    }
    return hp;
}
int total_max_mp(Player *p) {
    int mp = p->max_mp;
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) mp += p->equipment[i].mp_bonus;
    }
    return mp;
}

void print_status(Player *p) {
    printf("\n--- %s the %s (Lv.%d) ---\n", p->name, class_name(p->cls), p->level);
    printf("HP: %d/%d   MP: %d/%d\n", p->hp, total_max_hp(p), p->mp, total_max_mp(p));
    printf("EXP: %d/%d   Gold: %d\n", p->exp, p->exp_to_next, p->gold);
    printf("ATK:%d (base %d) DEF:%d (base %d)\n", total_attack(p), p->attack, total_defense(p), p->defense);
    printf("STR:%d AGI:%d INT:%d LUK:%d\n",
           p->strength, p->agility, p->intelligence, p->luck);
    printf("Dodge:%d%% Block:%d%%\n", p->dodge_chance, p->block_chance);
}

void print_skills(Player *p) {
    printf("\n-- Skills --\n");
    for (int i = 0; i < p->skill_count; i++) {
        if (p->skills[i].element != ELEM_NONE) {
            printf("%d) %s [%s] (Power:%d, MP:%d)\n",
                   i + 1, p->skills[i].name, element_name(p->skills[i].element),
                   p->skills[i].power, p->skills[i].mp_cost);
        } else {
            printf("%d) %s (Power:%d, MP:%d)\n",
                   i + 1, p->skills[i].name,
                   p->skills[i].power, p->skills[i].mp_cost);
        }
    }
}

void print_inventory(Player *p) {
    printf("\n-- Inventory --\n");
    if (p->item_count == 0) {
        printf("(empty)\n");
        return;
    }
    for (int i = 0; i < p->item_count; i++) {
        if (p->inventory[i].heal_amount > 0) {
            printf("%d) %s x%d (heals %d HP)\n",
                   i + 1, p->inventory[i].name,
                   p->inventory[i].quantity,
                   p->inventory[i].heal_amount);
        } else {
            printf("%d) %s x%d (restores MP)\n",
                   i + 1, p->inventory[i].name,
                   p->inventory[i].quantity);
        }
    }
}

void print_equipment(Player *p) {
    printf("\n-- Equipped --\n");
    for (int i = 0; i < MAX_EQUIP; i++) {
        if (p->has_equipment[i]) {
            Equipment *e = &p->equipment[i];
            printf("%s: %s [%s] (ATK+%d DEF+%d HP+%d MP+%d)\n",
                   slot_name((EquipSlot)i), e->name, rarity_name(e->rarity),
                   e->atk_bonus, e->def_bonus, e->hp_bonus, e->mp_bonus);
        } else {
            printf("%s: (empty)\n", slot_name((EquipSlot)i));
        }
    }
}

void show_stats(Player *p) {
    printf("\n========== PLAYER STATS ==========\n");
    print_status(p);
    printf("Kills: %d\n", p->kills);
    printf("Damage Dealt: %d\n", p->damage_dealt);
    printf("Damage Taken: %d\n", p->damage_taken);
    print_inventory(p);
    print_equipment(p);
    print_skills(p);
    printf("==================================\n");
}

/* ================= LEVEL UP ================= */
void level_up(Player *p) {
    while (p->exp >= p->exp_to_next) {
        p->exp -= p->exp_to_next;
        p->level++;
        p->exp_to_next = (int)(p->exp_to_next * 1.25);
        p->max_hp += 25;
        p->max_mp += 10;
        p->attack += 5;
        p->defense += 3;
        p->strength += 2;
        p->agility += 2;
        p->intelligence += 2;
        p->luck += 1;
        p->hp = total_max_hp(p);
        p->mp = total_max_mp(p);
        printf("\n*** LEVEL UP! %s is now level %d! ***\n", p->name, p->level);
        if (p->level % 5 == 0) {
            printf("*** BOSS LEVEL REACHED! ***\n");
        }
    }
}

void gain_exp(Player *p, int amount) {
    p->exp += amount;
    printf("%s gained %d EXP!\n", p->name, amount);
    level_up(p);
}

/* ================= EQUIPMENT GENERATION ================= */
/* Generate a random piece of equipment appropriate for a slot, scaled by level */
Equipment generate_equipment(EquipSlot slot, int level) {
    Equipment eq;
    eq.slot = slot;
    eq.equipped = 0;

    /* Determine rarity with weighted randomness (common = most likely) */
    int roll = r(1, 100);
    if (roll <= 50) eq.rarity = RARITY_COMMON;
    else if (roll <= 75) eq.rarity = RARITY_UNCOMMON;
    else if (roll <= 90) eq.rarity = RARITY_RARE;
    else if (roll <= 97) eq.rarity = RARITY_EPIC;
    else if (roll <= 99) eq.rarity = RARITY_LEGENDARY;
    else eq.rarity = RARITY_MYTHIC;

    int mult = rarity_multiplier(eq.rarity);
    int scale = (level / 2) + 1;

    eq.atk_bonus = 0;
    eq.def_bonus = 0;
    eq.hp_bonus = 0;
    eq.mp_bonus = 0;

    const char *base_name = "Item";
    switch (slot) {
        case SLOT_WEAPON:
            eq.atk_bonus = mult * scale * 2;
            base_name = "Blade";
            break;
        case SLOT_ARMOR:
            eq.def_bonus = mult * scale * 2;
            eq.hp_bonus = mult * scale;
            base_name = "Armor";
            break;
        case SLOT_HELMET:
            eq.def_bonus = mult * scale;
            eq.hp_bonus = mult * scale / 2 + 1;
            base_name = "Helm";
            break;
        case SLOT_SHIELD:
            eq.def_bonus = mult * scale * 2;
            base_name = "Shield";
            break;
        case SLOT_RING:
            eq.mp_bonus = mult * scale;
            eq.atk_bonus = mult * scale / 2;
            base_name = "Ring";
            break;
    }

    snprintf(eq.name, MAX_NAME, "%s %s", rarity_name(eq.rarity), base_name);
    return eq;
}

/* Equip an item into player's equipment slots */
void equip_item(Player *p, Equipment eq) {
    p->equipment[eq.slot] = eq;
    p->equipment[eq.slot].equipped = 1;
    p->has_equipment[eq.slot] = 1;
    printf("Equipped %s [%s] in slot %s!\n", eq.name, rarity_name(eq.rarity), slot_name(eq.slot));
}

/* ================= ENEMY ================= */
void init_enemy(Enemy *e, const char *name, int hp, int atk, int def,
                int exp, int gold, int is_boss, int is_elite, Element resist) {
    strncpy(e->name, name, MAX_NAME - 1);
    e->name[MAX_NAME - 1] = '\0';
    e->max_hp = hp;
    e->hp = hp;
    e->attack = atk;
    e->defense = def;
    e->exp_reward = exp;
    e->gold_reward = gold;
    e->is_boss = is_boss;
    e->is_elite = is_elite;
    e->resist = resist;
    e->status = STATUS_NONE;
    e->status_turns = 0;
}

Enemy create_enemy(Player *p, int map) {
    Enemy e;
    if (p->level % 5 == 0) {
        const char *boss_name;
        Element resist = ELEM_NONE;
        if (map == 1) { boss_name = "Forest King Thornroot"; resist = ELEM_NONE; }
        else if (map == 2) { boss_name = "Skeleton King Xerath"; resist = ELEM_ICE; }
        else if (map == 3) { boss_name = "Shadow Emperor Nocturn"; resist = ELEM_LIGHTNING; }
        else { boss_name = "Chaos Titan Zorath"; resist = ELEM_FIRE; }
        init_enemy(&e, boss_name,
                   200 + p->level * 30,
                   25 + p->level * 4,
                   10 + p->level,
                   90, 150, 1, 0, resist);
        printf("\n*** BOSS BATTLE: %s appears! ***\n", e.name);
    } else {
        const char *forest[] = {"Wolf", "Vine Stalker", "Forest Hunter", "Root Beast"};
        const char *dungeon[] = {"Skeleton Knight", "Cursed Armor", "Dark Prisoner", "Blood Warden"};
        const char *dark[] = {"Void Walker", "Shadow Reaper", "Nightmare", "Soul Devourer"};
        const char *chaos[] = {"Flame Demon", "Chaos Beast", "Rift Walker", "Infernal Shade"};
        const char *pick_name;
        int pick = r(0, 3);
        Element resist = ELEM_NONE;
        if (map == 1) { pick_name = forest[pick]; }
        else if (map == 2) { pick_name = dungeon[pick]; resist = ELEM_ICE; }
        else if (map == 3) { pick_name = dark[pick]; resist = ELEM_LIGHTNING; }
        else { pick_name = chaos[pick]; resist = ELEM_FIRE; }

        /* 15% chance for an Elite variant */
        int is_elite = (r(1, 100) <= 15);

        int hp = 60 + p->level * 10;
        int atk = 10 + p->level * 2;
        int def = 5 + p->level;
        int exp_r = 40;
        int gold_r = 50;

        if (is_elite) {
            hp = (int)(hp * 1.8);
            atk = (int)(atk * 1.4);
            def = (int)(def * 1.4);
            exp_r = (int)(exp_r * 2);
            gold_r = (int)(gold_r * 2);
        }

        init_enemy(&e, pick_name, hp, atk, def, exp_r, gold_r, 0, is_elite, resist);

        if (is_elite) {
            printf("\n=== An ELITE %s appears! Be careful! (HP:%d) ===\n", e.name, e.max_hp);
        } else {
            printf("\n=== A wild %s appears! (HP:%d) ===\n", e.name, e.max_hp);
        }
    }
    return e;
}

/* ================= STATUS EFFECTS ================= */
/* Apply a status effect to enemy based on skill element */
void apply_status_from_element(Enemy *e, Element elem) {
    int chance = r(1, 100);
    if (chance > 35) return; /* 35% chance to apply */

    switch (elem) {
        case ELEM_FIRE:
            if (e->resist != ELEM_FIRE) {
                e->status = STATUS_BURN;
                e->status_turns = 3;
                printf("%s is now Burning!\n", e->name);
            }
            break;
        case ELEM_ICE:
            if (e->resist != ELEM_ICE) {
                e->status = STATUS_FREEZE;
                e->status_turns = 2;
                printf("%s is Frozen!\n", e->name);
            }
            break;
        case ELEM_LIGHTNING:
            if (e->resist != ELEM_LIGHTNING) {
                e->status = STATUS_STUN;
                e->status_turns = 1;
                printf("%s is Stunned!\n", e->name);
            }
            break;
        default:
            break;
    }
}

/* Process enemy status effect at start of its turn.
   Returns 1 if enemy's turn should be skipped (Stun/Freeze). */
int process_enemy_status(Enemy *e) {
    if (e->status == STATUS_NONE) return 0;

    int skip_turn = 0;

    switch (e->status) {
        case STATUS_BURN:
            {
                int dmg = e->max_hp / 20;
                if (dmg < 1) dmg = 1;
                e->hp -= dmg;
                if (e->hp < 0) e->hp = 0;
                printf("%s suffers %d Burn damage! (HP: %d/%d)\n", e->name, dmg, e->hp, e->max_hp);
            }
            break;
        case STATUS_POISON:
            {
                int dmg = e->max_hp / 15;
                if (dmg < 1) dmg = 1;
                e->hp -= dmg;
                if (e->hp < 0) e->hp = 0;
                printf("%s suffers %d Poison damage! (HP: %d/%d)\n", e->name, dmg, e->hp, e->max_hp);
            }
            break;
        case STATUS_FREEZE:
            printf("%s is Frozen and can't move!\n", e->name);
            skip_turn = 1;
            break;
        case STATUS_STUN:
            printf("%s is Stunned and can't move!\n", e->name);
            skip_turn = 1;
            break;
        default:
            break;
    }

    e->status_turns--;
    if (e->status_turns <= 0) {
        e->status = STATUS_NONE;
    }

    return skip_turn;
}

/* ================= COMBAT ================= */
int is_critical(Player *p) {
    int chance = 5 + p->luck;
    return (rand() % 100) < chance;
}

int calc_damage(int attack, int defense) {
    int dmg = roll_damage(attack) - defense;
    if (dmg < 1) dmg = 1;
    return dmg;
}

/* Apply elemental resistance: halves damage if enemy resists the element */
int apply_elemental_resist(int dmg, Element atk_elem, Enemy *e) {
    if (atk_elem != ELEM_NONE && atk_elem == e->resist) {
        printf("%s resists %s damage!\n", e->name, element_name(atk_elem));
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
    }
    return dmg;
}

void player_attack(Player *p, Enemy *e) {
    int dmg = calc_damage(total_attack(p), e->defense);
    if (is_critical(p)) {
        dmg *= 2;
        printf("CRITICAL HIT! ");
    }
    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    printf("%s attacks %s for %d damage! (%s HP: %d/%d)\n",
           p->name, e->name, dmg, e->name, e->hp, e->max_hp);
}

void player_use_skill(Player *p, Enemy *e, int skill_index) {
    if (skill_index < 0 || skill_index >= p->skill_count) {
        printf("Invalid skill.\n");
        return;
    }
    Skill *s = &p->skills[skill_index];
    if (p->mp < s->mp_cost) {
        printf("Not enough MP!\n");
        return;
    }
    p->mp -= s->mp_cost;

    if (strcmp(s->name, "Heal") == 0) {
        int heal = s->power + p->intelligence;
        p->hp += heal;
        if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
        printf("%s casts Heal and recovers %d HP! (HP: %d/%d)\n",
               p->name, heal, p->hp, total_max_hp(p));
        return;
    }

    int base = s->power + p->intelligence * 2;
    if (strcmp(s->name, "Lightning Smite") == 0 || strcmp(s->name, "Ice Shard") == 0) {
        base += r(0, 20);
    }

    int dmg = calc_damage(base, e->defense);
    dmg = apply_elemental_resist(dmg, s->element, e);

    if (is_critical(p)) {
        dmg = (int)(dmg * 1.5);
        printf("CRITICAL SKILL HIT! ");
    }

    e->hp -= dmg;
    if (e->hp < 0) e->hp = 0;
    p->damage_dealt += dmg;
    printf("%s casts %s on %s for %d damage! (%s HP: %d/%d)\n",
           p->name, s->name, e->name, dmg, e->name, e->hp, e->max_hp);

    apply_status_from_element(e, s->element);
}

void use_item(Player *p, int index) {
    if (index < 0 || index >= p->item_count) {
        printf("Invalid item.\n");
        return;
    }
    Item *it = &p->inventory[index];
    if (it->quantity <= 0) {
        printf("You have none of that left.\n");
        return;
    }
    if (it->heal_amount > 0) {
        p->hp += it->heal_amount;
        if (p->hp > total_max_hp(p)) p->hp = total_max_hp(p);
        printf("Used %s, healed %d HP! (HP: %d/%d)\n",
               it->name, it->heal_amount, p->hp, total_max_hp(p));
    } else if (strcmp(it->name, "Mana Potion") == 0) {
        int restore = 30;
        p->mp += restore;
        if (p->mp > total_max_mp(p)) p->mp = total_max_mp(p);
        printf("Used %s, restored %d MP! (MP: %d/%d)\n",
               it->name, restore, p->mp, total_max_mp(p));
    }
    it->quantity--;
}

/* Returns 1 if the player successfully dodged the attack */
int try_dodge(Player *p) {
    return (r(1, 100) <= p->dodge_chance);
}
/* Returns 1 if the player blocked (halves damage) */
int try_block(Player *p) {
    return (r(1, 100) <= p->block_chance);
}

void enemy_attack(Enemy *e, Player *p) {
    if (try_dodge(p)) {
        printf("%s dodges %s's attack completely!\n", p->name, e->name);
        return;
    }

    int dmg = calc_damage(e->attack, total_defense(p) + p->agility / 2);

    if (try_block(p)) {
        dmg = dmg / 2;
        if (dmg < 1) dmg = 1;
        printf("%s blocks the attack, reducing damage!\n", p->name);
    }

    p->hp -= dmg;
    if (p->hp < 0) p->hp = 0;
    p->damage_taken += dmg;
    printf("%s attacks %s for %d damage! (HP: %d/%d)\n",
           e->name, p->name, dmg, p->hp, total_max_hp(p));
}

/* ================= LOOT DROPS ================= */
/* On enemy defeat, possibly drop equipment or items */
void roll_loot_drop(Player *p, Enemy *e, int map) {
    int drop_chance = e->is_boss ? 100 : (e->is_elite ? 60 : 25);

    if (r(1, 100) > drop_chance) {
        return; /* no drop */
    }

    /* Decide between equipment drop or item drop */
    int kind = r(1, 100);

    if (kind <= 60) {
        /* Equipment drop */
        EquipSlot slot = (EquipSlot)r(0, MAX_EQUIP - 1);
        Equipment eq = generate_equipment(slot, p->level);

        /* Bosses guarantee at least Epic rarity */
        if (e->is_boss && eq.rarity < RARITY_EPIC) {
            eq.rarity = RARITY_EPIC;
            int mult = rarity_multiplier(eq.rarity);
            int scale = (p->level / 2) + 1;
            switch (slot) {
                case SLOT_WEAPON: eq.atk_bonus = mult * scale * 2; break;
                case SLOT_ARMOR: eq.def_bonus = mult * scale * 2; eq.hp_bonus = mult * scale; break;
                case SLOT_HELMET: eq.def_bonus = mult * scale; eq.hp_bonus = mult * scale / 2 + 1; break;
                case SLOT_SHIELD: eq.def_bonus = mult * scale * 2; break;
                case SLOT_RING: eq.mp_bonus = mult * scale; eq.atk_bonus = mult * scale / 2; break;
            }
            snprintf(eq.name, MAX_NAME, "%s %s", rarity_name(eq.rarity),
                     slot == SLOT_WEAPON ? "Blade" :
                     slot == SLOT_ARMOR ? "Armor" :
                     slot == SLOT_HELMET ? "Helm" :
                     slot == SLOT_SHIELD ? "Shield" : "Ring");
        }

        printf("\n*** LOOT: %s found a %s [%s]! ***\n", p->name, eq.name, rarity_name(eq.rarity));
        printf("Stats: ATK+%d DEF+%d HP+%d MP+%d\n", eq.atk_bonus, eq.def_bonus, eq.hp_bonus, eq.mp_bonus);

        /* Auto-equip if slot empty, otherwise ask */
        if (!p->has_equipment[slot]) {
            equip_item(p, eq);
        } else {
            printf("Replace your current %s? (1=Yes, 0=No): ", slot_name(slot));
            int choice;
            if (scanf("%d", &choice) == 1 && choice == 1) {
                equip_item(p, eq);
            } else {
                printf("Item discarded.\n");
            }
        }
    } else {
        /* Item drop */
        if (r(1, 100) <= 60) {
            add_item(p, "Health Potion", 1, 40);
            printf("\n*** LOOT: %s found a Health Potion! ***\n", p->name);
        } else {
            add_item(p, "Mana Potion", 1, 0);
            printf("\n*** LOOT: %s found a Mana Potion! ***\n", p->name);
        }
    }
}

/* ================= SHOP ================= */
void shop_menu(Player *p) {
    int running = 1;
    while (running) {
        printf("\n========== SHOP ==========\n");
        printf("Gold: %d\n", p->gold);
        printf("1. Buy Health Potion (20 gold, heals 40 HP)\n");
        printf("2. Buy Mana Potion (15 gold, restores 30 MP)\n");
        printf("3. Buy Random Equipment (50 gold)\n");
        printf("4. Sell an item\n");
        printf("5. Leave Shop\n");
        printf("Choice: ");
        int choice;
        if (scanf("%d", &choice) != 1) {
            while (getchar() != '\n');
            printf("Invalid input.\n");
            continue;
        }
        switch (choice) {
            case 1:
                if (p->gold >= 20) {
                    p->gold -= 20;
                    add_item(p, "Health Potion", 1, 40);
                    printf("Bought a Health Potion!\n");
                } else {
                    printf("Not enough gold!\n");
                }
                break;
            case 2:
                if (p->gold >= 15) {
                    p->gold -= 15;
                    add_item(p, "Mana Potion", 1, 0);
                    printf("Bought a Mana Potion!\n");
                } else {
                    printf("Not enough gold!\n");
                }
                break;
            case 3:
                if (p->gold >= 50) {
                    p->gold -= 50;
                    EquipSlot slot = (EquipSlot)r(0, MAX_EQUIP - 1);
                    Equipment eq = generate_equipment(slot, p->level);
                    printf("You bought: %s [%s] for slot %s\n",
                           eq.name, rarity_name(eq.rarity), slot_name(slot));
                    printf("Stats: ATK+%d DEF+%d HP+%d MP+%d\n",
                           eq.atk_bonus, eq.def_bonus, eq.hp_bonus, eq.mp_bonus);
                    if (!p->has_equipment[slot]) {
                        equip_item(p, eq);
                    } else {
                        printf("Replace your current %s? (1=Yes, 0=No): ", slot_name(slot));
                        int c;
                        if (scanf("%d", &c) == 1 && c == 1) {
                            equip_item(p, eq);
                        } else {
                            printf("Item discarded.\n");
                        }
                    }
                } else {
                    printf("Not enough gold!\n");
                }
                break;
            case 4: {
                print_inventory(p);
                printf("Choose item to sell (0 to cancel): ");
                int idx;
                if (scanf("%d", &idx) != 1) {
                    while (getchar() != '\n');
                    printf("Invalid input.\n");
                    continue;
                }
                if (idx == 0) break;
                idx--;
                if (idx < 0 || idx >= p->item_count) {
                    printf("Invalid item.\n");
                    break;
                }
                if (p->inventory[idx].quantity <= 0) {
                    printf("You have none of that to sell.\n");
                    break;
                }
                int sell_price = 10;
                p->inventory[idx].quantity--;
                p->gold += sell_price;
                printf("Sold %s for %d gold!\n", p->inventory[idx].name, sell_price);
                break;
            }
            case 5:
                running = 0;
                break;
            default:
                printf("Invalid choice.\n");
                break;
        }
    }
}

/* ================= SAVE / LOAD ================= */
#define SAVE_FILE "starzilla_save.dat"

void save_game(Player *p, int map) {
    FILE *f = fopen(SAVE_FILE, "wb");
    if (!f) {
        printf("Failed to save game.\n");
        return;
    }
    fwrite(&map, sizeof(int), 1, f);
    fwrite(p, sizeof(Player), 1, f);
    fclose(f);
    printf("Game saved successfully!\n");
}

int load_game(Player *p, int *map) {
    FILE *f = fopen(SAVE_FILE, "rb");
    if (!f) {
        return 0; /* no save file */
    }
    fread(map, sizeof(int), 1, f);
    fread(p, sizeof(Player), 1, f);
    fclose(f);
    return 1;
}

/* ================= BATTLE ================= */
int battle(Player *p, int map) {
    Enemy e = create_enemy(p, map);

    while (p->hp > 0 && e.hp > 0) {
        print_status(p);
        printf("\n%s HP: %d/%d", e.name, e.hp, e.max_hp);
        if (e.status != STATUS_NONE) {
            printf(" [%s]", status_name(e.status));
        }
        printf("\n");
        printf("\n1) Attack\n");
        printf("2) Skill\n");
        printf("3) Item\n");
        printf("4) Flee\n");
        printf("> ");
        int choice;
        if (scanf("%d", &choice) != 1) {
            while (getchar() != '\n');
            printf("Invalid input.\n");
            continue;
        }
        switch (choice) {
            case 1:
                player_attack(p, &e);
                break;
            case 2: {
                print_skills(p);
                printf("Choose skill: ");
                int s;
                if (scanf("%d", &s) != 1) {
                    while (getchar() != '\n');
                    printf("Invalid input.\n");
                    continue;
                }
                player_use_skill(p, &e, s - 1);
                break;
            }
            case 3: {
                print_inventory(p);
                printf("Choose item: ");
                int it;
                if (scanf("%d", &it) != 1) {
                    while (getchar() != '\n');
                    printf("Invalid input.\n");
                    continue;
                }
                use_item(p, it - 1);
                break;
            }
            case 4:
                if (r(0, 1)) {
                    printf("You successfully fled!\n");
                    return 0;
                }
                printf("Couldn't escape!\n");
                break;
            default:
                printf("Invalid choice.\n");
                continue;
        }

        if (e.hp <= 0) {
            printf("\n%s defeated %s!\n", p->name, e.name);
            p->kills++;
            p->gold += e.gold_reward;
            gain_exp(p, e.exp_reward);
            printf("Gained %d gold!\n", e.gold_reward);
            if (e.is_boss) {
                printf("BOSS CLEARED! Amazing!\n");
            }
            roll_loot_drop(p, &e, map);
            return 1;
        }

        /* Enemy turn (may be skipped due to status effect) */
        int skip = process_enemy_status(&e);
        if (!skip) {
            enemy_attack(&e, p);
        }

        if (p->hp <= 0) {
            printf("\n%s has been defeated...\n", p->name);
            return -1;
        }
    }
    return 0;
}

/* ================= MAIN ================= */
int main(void) {
    srand((unsigned int)time(NULL));
    Player player;
    char name[MAX_NAME];
    int map;

    printf("=================================\n");
    printf("       STARZILLA RPG\n");
    printf("=================================\n");

    /* Check for existing save */
    printf("\n1. New Game\n");
    printf("2. Load Game\n");
    printf("Choice: ");
    int start_choice;
    if (scanf("%d", &start_choice) != 1) {
        while (getchar() != '\n');
        start_choice = 1;
    }

    if (start_choice == 2) {
        if (load_game(&player, &map)) {
            printf("\nGame loaded! Welcome back, %s the %s (Lv.%d)!\n",
                   player.name, class_name(player.cls), player.level);
        } else {
            printf("\nNo save file found. Starting a new game.\n");
            start_choice = 1;
        }
    }

    if (start_choice != 2) {
        show_rules();
        ClassType cls = choose_class();
        map = choose_map();
        printf("\nEnter your character's name: ");
        if (scanf("%31s", name) != 1) {
            strcpy(name, "Hero");
        }
        init_player(&player, name, cls);
        printf("\nWelcome, %s the %s! Your adventure begins.\n", player.name, class_name(player.cls));
    }

    while (1) {
        int choice;
        printf("\n===== MAIN MENU =====\n");
        printf("1. Battle\n");
        printf("2. Stats / Inventory\n");
        printf("3. Shop\n");
        printf("4. Save Game\n");
        printf("5. Exit\n");
        printf("Choice: ");
        if (scanf("%d", &choice) != 1) {
            while (getchar() != '\n');
            printf("Invalid input.\n");
            continue;
        }
        if (choice == 1) {
            int result = battle(&player, map);
            if (result == -1) {
                printf("\nGAME OVER\n");
                show_stats(&player);
                /* remove save on death so player must start fresh */
                remove(SAVE_FILE);
                break;
            }
        } else if (choice == 2) {
            show_stats(&player);
        } else if (choice == 3) {
            shop_menu(&player);
        } else if (choice == 4) {
            save_game(&player, map);
        } else if (choice == 5) {
            printf("\nGoodbye, %s!\n", player.name);
            show_stats(&player);
            break;
        } else {
            printf("Invalid choice.\n");
        }
    }
    return 0;
}
