                printf("\nSave before quitting? (1=Yes): ");
                int save_quit = get_valid_input(1, 2);
                if (save_quit == 1) {
                    printf("Save slot (1-3): ");
                    int quit_slot = get_valid_input(1, 3);
                    save_game_slot(&player, map, quit_slot);
                }
                show_stats(&player);
                printf("\n⭐ Thank you for playing Starzilla RPG! ⭐\n");
                show_anime_quote();
                return 0;
        }
    }
    return 0;
}
