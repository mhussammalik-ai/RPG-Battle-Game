void level_up(Player *p) {
    while (p->exp >= p->exp_to_next) {
        p->exp -= p->exp_to_next;
        p->level++;
        p->exp_to_next = (int)(p->exp_to_next * 1.25);
        
        p->max_hp += 25 + p->stamina;
        p->max_mp += 10 + p->intelligence / 2;
        p->attack += 5;
        p->defense += 3;
        p->strength += 2;
        p->agility += 2;
        p->intelligence += 2;
        p->luck += 1;
        p->stamina += 2;
        
        p->hp = total_max_hp(p);
        p->mp = total_max_mp(p);
        
        printf("\n========================================\n");
        printf("     🌟 LEVEL UP! %s is now level %d! 🌟\n", p->name, p->level);
        printf("========================================\n");
        show_anime_quote();
        
        if (p->level % 5 == 0) {
            printf("*** ⚔️ BOSS LEVEL REACHED! ⚔️ ***\n");
        }
        
        if (p->level == 10) p->achievements[0] = 1;
        if (p->level == 25) p->achievements[1] = 1;
        if (p->level == 50) p->achievements[2] = 1;
    }
}

void gain_exp(Player *p, int amount) {
    p->exp += amount;
    printf("\n%s gained %d EXP!\n", p->name, amount);
    level_up(p);
}

