int main(void) {
    srand((unsigned int)time(NULL));
    Player player;
    char name[MAX_NAME];
    int map = 1;
    
    print_header("STARZILLA RPG BATTLE GAME");
    printf("|  An Epic Text-Based Adventure!                  |\n");
    print_footer();
    show_anime_quote();
    
    print_header("SAVE / LOAD MENU");
    printf("|  1. New Game                                    |\n");
    printf("|  2. Load Game                                   |\n");
    printf("|  3. List Save Slots                             |\n");
    print_footer();
    printf("\nChoice: ");
    
    int start = get_valid_input(1, 3);
    
    if (start == 2) {
        list_save_slots();
        printf("\nEnter save slot (1-3): ");
        int slot = get_valid_input(1, 3);
        if (load_game_slot(&player, &map, slot)) {
            print_header("GAME LOADED SUCCESSFULLY!");
            printf("|  Welcome back, %s the %s (Lv.%d)!          |\n",
                   player.name, class_name(player.cls), player.level);
            print_footer();
            show_anime_quote();
            printf("\nPress Enter to continue...");
            getchar();
        } else {
            printf("\nNo save found. Starting new game.\n");
            start = 1;
        }
    }
    
    if (start == 3) {
        list_save_slots();
        printf("\n1. New Game\n2. Load Game\nChoice: ");
        int choice = get_valid_input(1, 2);
        if (choice == 2) {
            printf("Enter save slot (1-3): ");
            int slot = get_valid_input(1, 3);
            if (!load_game_slot(&player, &map, slot)) {
                printf("No save found. Starting new game.\n");
                start = 1;
            } else {
                print_header("GAME LOADED SUCCESSFULLY!");
                printf("|  Welcome back, %s the %s (Lv.%d)!          |\n",
                       player.name, class_name(player.cls), player.level);
                print_footer();
                show_anime_quote();
                printf("\nPress Enter to continue...");
                getchar();
                start = 2;
            }
        } else {
            start = 1;
        }
    }
    
    if (start != 2) {
        show_rules();
        ClassType cls = choose_class();
        map = choose_map();
        printf("\nEnter your character's name: ");
        fgets(name, sizeof(name), stdin);
        name[strcspn(name, "\n")] = '\0';
        if (strlen(name) == 0) {
            strcpy(name, "Hero");
        }
        
        init_player(&player, name, cls);
        
        print_header("WELCOME TO THE GAME!");
        printf("|  Welcome, %s the %s!                         |\n", player.name, class_name(player.cls));
        printf("|  Your adventure begins now...                  |\n");
        print_footer();
        show_anime_quote();
        printf("\nPress Enter to continue...");
        getchar();
    }
    
    while (1) {
        print_header("MAIN MENU");
        printf("|  1. Battle                                     |\n");
        printf("|  2. Stats & Inventory                          |\n");
        printf("|  3. Shop                                       |\n");
        printf("|  4. Save Game                                  |\n");
        printf("|  5. Load Game                                  |\n");
        printf("|  6. Battle History                             |\n");
        printf("|  7. Achievements                               |\n");
        printf("|  8. Generate Battle Report                     |\n");
        printf("|  9. Exit                                       |\n");
        print_footer();
        printf("Choice: ");
        
        int choice = get_valid_input(1, 9);
        
        switch(choice) {
            case 1: {
                int result = battle(&player, map);
                if (result == -1) {
                    show_game_over(&player);
                    save_battle_report(&player, map);
                    return 0;
                }
                if (result == 1) {
                    save_game_slot(&player, map, 1);
                    printf("\nAuto-saved to slot 1\n");
                }
                break;
            }
            case 2: {
                show_stats(&player);
                break;
            }
            case 3: {
                print_header("SHOP");
                printf("\nGold: %d\n", player.gold);
                print_header("SHOP ITEMS");
                printf("|  1. Health Potion (20g) - Heals 40 HP     |\n");
                printf("|  2. Mana Potion (15g) - Restores 30 MP    |\n");
                printf("|  3. Bread (10g) - Heals 15 HP             |\n");
                printf("|  4. Leave Shop                             |\n");
                print_footer();
                printf("\nChoice: ");
                
                int shop_choice = get_valid_input(1, 4);
                
                if (shop_choice == 1 && player.gold >= 20) {
                    player.gold -= 20;
                    add_item(&player, "Health Potion", 1, 40, 0);
                    printf("Bought Health Potion!\n");
                } else if (shop_choice == 2 && player.gold >= 15) {
                    player.gold -= 15;
                    add_item(&player, "Mana Potion", 1, 0, 30);
                    printf("Bought Mana Potion!\n");
                } else if (shop_choice == 3 && player.gold >= 10) {
                    player.gold -= 10;
                    add_item(&player, "Bread", 1, 15, 0);
                    printf("Bought Bread!\n");
                } else if (shop_choice == 4) {
                    printf("Leaving shop.\n");
                } else {
                    printf("Not enough gold or invalid choice!\n");
                }
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 4: {
                list_save_slots();
                printf("\nSave slot (1-3): ");
                int slot = get_valid_input(1, 3);
                save_game_slot(&player, map, slot);
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 5: {
                list_save_slots();
                printf("\nLoad slot: ");
                int load_slot = get_valid_input(1, 3);
                if (load_game_slot(&player, &map, load_slot)) {
                    print_header("GAME LOADED SUCCESSFULLY!");
                    printf("|  Welcome back, %s the %s (Lv.%d)!          |\n",
                           player.name, class_name(player.cls), player.level);
                    print_footer();
                    show_anime_quote();
                } else {
                    printf("Failed to load game!\n");
                }
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 6: {
                display_battle_history(&player);
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 7: {
                show_achievements(&player);
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 8: {
                save_battle_report(&player, map);
                printf("\nPress Enter to continue...");
                getchar();
                break;
            }
            case 9: {
                print_header("GOODBYE!");
                printf("|  Thanks for playing, %s!                   |\n", player.name);
                print_footer();
                printf("\nSave before quitting? (1=Yes): ");
                int save_quit = get_valid_input(1, 2);
                if (save_quit == 1) {
                    printf("Save slot (1-3): ");
                    int quit_slot = get_valid_input(1, 3);
                    save_game_slot(&player, map, quit_slot);
                    save_battle_report(&player, map);
                }
                printf("\nFinal report saved to: battle_report.txt\n");
                return 0;
            }
        }
    }
}
