}

void generateEnemy(Player p, Enemy *e, int dungeonFloor) {
    const char *normalNames[] = {"Goblin", "Wolf", "Orc", "Skeleton", "Bandit"};
    const char *eliteNames[] = {"Ogre", "Troll", "Dark Knight", "Vampire"};
    const char *bossNames[] = {"Dragon", "Lich King", "Demon Lord", "Ancient Titan"};
    
    int levelMod = p.level + dungeonFloor;
    
    if (dungeonFloor > 0 && dungeonFloor % 5 == 0) {
        e->type = 3;
        strcpy(e->name, bossNames[rand() % 4]);
        e->maxHp = 200 + (levelMod * 15);
        e->attack = 25 + (levelMod * 3);
        e->defense = 15 + (levelMod * 2);
        e->magic = 20 + (levelMod * 2);
        e->speed = 10 + (levelMod);
        e->expReward = 500 + (levelMod * 30);
        e->goldReward = 300 + (levelMod * 20);
        e->level = levelMod;
        e->phase = 1;
        strcpy(e->specialAbility, "Rage Mode");
    } else if (rand() % 100 < 20 || dungeonFloor > 0) {
        e->type = 2;
        strcpy(e->name, eliteNames[rand() % 4]);
        e->maxHp = 100 + (levelMod * 10);
        e->attack = 18 + (levelMod * 2);
        e->defense = 10 + (levelMod);
        e->magic = 12 + (levelMod);
        e->speed = 8 + (levelMod);
        e->expReward = 150 + (levelMod * 15);
        e->goldReward = 100 + (levelMod * 10);
        e->level = levelMod;
        e->phase = 0;
        strcpy(e->specialAbility, "Berserk");
    } else {
        e->type = 1;
        strcpy(e->name, normalNames[rand() % 5]);
        e->maxHp = 50 + (levelMod * 6);
        e->attack = 10 + (levelMod);
        e->defense = 5 + (levelMod);
        e->magic = 5 + (levelMod);
        e->speed = 5 + (levelMod);
        e->expReward = 50 + (levelMod * 8);
        e->goldReward = 30 + (levelMod * 5);
        e->level = levelMod;
        e->phase = 0;
        strcpy(e->specialAbility, "None");
    }
    
    e->hp = e->maxHp;
    e->effectChance = rand() % 30 + 10;
    e->effect = (rand() % 5);
}

void battle(Player *p, Enemy *e) {
    int inBattle = 1;
    int combo = 0;
    
    printf("\n⚔️ BATTLE STARTED! ⚔️\n");
    printf("%s vs %s (Level %d)\n", p->name, e->name, e->level);
    if (e->type == 3) printf("⚠️ BOSS ENCOUNTER! ⚠️\n");
    
    while (inBattle) {
        displayStatus(*p, *e);
        
        // Speed-based turn order
        if (p->speed >= e->speed) {
            playerTurn(p, e);
            if (e->hp <= 0) break;
            enemyTurn(p, e);
        } else {
            enemyTurn(p, e);
            if (p->hp <= 0) break;
            playerTurn(p, e);
        }
        
        if (e->hp <= 0) {
            printf("\n✨ VICTORY! ✨\n");
            p->kills++;
            p->score += 100 * e->type;
            p->gold += e->goldReward;
            gainExp(p, e->expReward);
            randomLoot(p, *e);
            
            // Combo bonus
            if (combo >= 3) {
                printf("🏆 %d Hit Combo! Bonus gold! 🏆\n", combo);
                p->gold += combo * 10;
            }
            
            inBattle = 0;
        }
        
        if (p->hp <= 0) {
            printf("\n💀 DEFEATED! 💀\n");
            p->hp = p->maxHp / 2;
            p->gold /= 2;
            printf("You wake up at the inn. Lost half your gold.\n");
            inBattle = 0;
        }
    }
}

void displayStatus(Player p, Enemy e) {
    printf("\n┌─────────────────────────────────────────┐\n");
    printf("│ %s (Lv.%d) %10s (Lv.%d) │\n", 
           p.name, p.level, e.name, e.level);
    printf("│ HP: %3d/%3d  MP: %3d/%3d    HP: %3d/%3d     │\n",
           p.hp, p.maxHp, p.mp, p.maxMp, e.hp, e.maxHp);
    printf("│ ATK:%3d DEF:%3d MAG:%3d   ATK:%3d DEF:%3d │\n",
           p.attack, p.defense, p.magic, e.attack, e.defense);
    printf("└─────────────────────────────────────────┘\n");
}

void playerTurn(Player *p, Enemy *e) {
    int choice;
    static int combo = 0;
    
    printf("\n1. ⚔ Attack  2. ✨ Skill  3. 💊 Item  4. 🛡 Defend  5. 🏃 Flee\n");
    printf("Choice: ");
    scanf("%d", &choice);
    
    switch(choice) {
        case 1: {
            int damage = rand() % 20 + p->attack - e->defense/2;
            if (damage < 5) damage = 5;
            
            calculateCritical(*p, &damage);
            
            e->hp -= damage;
            printf("You deal %d damage!\n", damage);
            combo++;
            comboSystem(&combo, damage);
            break;
        }
        case 2:
            useSkill(p, e);
            combo = 0;
            break;
        case 3:
            useItem(p, e);
            combo = 0;
            break;
        case 4:
            printf("Defense increased for next turn!\n");
            p->defense += 5;
            combo = 0;
            break;
        case 5:
            if (rand() % 2 == 0) {
                printf("You escaped!\n");
                e->hp = 0;
            } else {
                printf("Failed to escape!\n");
            }
            combo = 0;
            break;
    }
}

void enemyTurn(Player *p, Enemy *e) {
    printf("\n💀 %s attacks! 💀\n", e->name);
    
    int damage = rand() % 15 + e->attack - p->defense/3;
    if (damage < 5) damage = 5;
    
    // Enemy special abilities
    if (e->type == 3 && e->hp < e->maxHp/2 && e->phase == 1) {
        printf("🔥 %s enters RAGE MODE! 🔥\n", e->name);
        damage *= 2;
        e->phase = 2;
    }
    
    if (rand() % 100 < e->effectChance) {
        printf("⚠️ %s inflicts a status effect! ⚠️\n", e->name);
        applyStatusEffect(p, e->effect, 3);
    }
    
    p->hp -= damage;
    printf("%s deals %d damage to you!\n", e->name, damage);
    
    // Apply active effects
    if (p->effectDuration > 0) {
        switch(p->activeEffect) {
            case EFFECT_POISON:
                p->hp -= 5;
                printf("☠️ Poison deals 5 damage! ☠️\n");
                break;
            case EFFECT_BURN:
                p->hp -= 8;
                printf("🔥 Burn deals 8 damage! 🔥\n");
                break;
        }
        p->effectDuration--;
    }
}

void useSkill(Player *p, Enemy *e) {
    printf("\n=== SKILLS ===\n");
    for (int i = 0; i < p->skillCount; i++) {
        if (p->level >= p->skills[i].requiredLevel) {
            printf("%d. %s (MP: %d) - %s\n", i+1, p->skills[i].name, 
                   p->skills[i].mpCost, p->skills[i].description);
        }
    }
    printf("0. Cancel\nChoice: ");
    
    int choice;
    scanf("%d", &choice);
    if (choice == 0) return;
    
    choice--;
    if (choice >= 0 && choice < p->skillCount && p->level >= p->skills[choice].requiredLevel) {
        if (p->mp >= p->skills[choice].mpCost) {
            p->mp -= p->skills[choice].mpCost;
            
            if (p->skills[choice].minDamage < 0) {
                p->hp -= p->skills[choice].minDamage;
                if (p->hp > p->maxHp) p->hp = p->maxHp;
                printf("💚 Restored %d HP!\n", -p->skills[choice].minDamage);
            } else {
                int damage = rand() % (p->skills[choice].maxDamage - p->skills[choice].minDamage + 1)
                           + p->skills[choice].minDamage + p->magic;
                damage -= e->defense/2;
                if (damage < 10) damage = 10;
                
                e->hp -= damage;
                printf("✨ %s deals %d damage! ✨\n", p->skills[choice].name, damage);
                
                // Apply status effect
                if (rand() % 100 < p->skills[choice].effectChance) {
                    printf("⚠️ Status effect applied! ⚠️\n");
                    applyStatusEffect(e, p->skills[choice].effect, 3);
                }
            }
        } else {
            printf("Not enough MP!\n");
        }
    }
}

void useItem(Player *p, Enemy *e) {
    printf("\n=== ITEMS ===\n");
    for (int i = 0; i < p->inventoryCount; i++) {
        printf("%d. %s x%d (%s)\n", i+1, p->inventory[i].name, 
               p->inventory[i].quantity, p->inventory[i].type);
    }
    printf("0. Cancel\nChoice: ");
    
    int choice;
    scanf("%d", &choice);
    if (choice == 0) return;
    
    choice--;
    if (choice >= 0 && choice < p->inventoryCount && p->inventory[choice].quantity > 0) {
        if (strcmp(p->inventory[choice].type, "healing") == 0) {
            p->hp += p->inventory[choice].effect;
            if (p->hp > p->maxHp) p->hp = p->maxHp;
            printf("💊 Used %s! HP: %d/%d\n", p->inventory[choice].name, p->hp, p->maxHp);
        } else if (strcmp(p->inventory[choice].type, "mana") == 0) {
            p->mp += p->inventory[choice].effect;
            if (p->mp > p->maxMp) p->mp = p->maxMp;
            printf("🔮 Used %s! MP: %d/%d\n", p->inventory[choice].name, p->mp, p->maxMp);
        }
        p->inventory[choice].quantity--;
        if (p->inventory[choice].quantity == 0) {
            for (int i = choice; i < p->inventoryCount - 1; i++) {
                p->inventory[i] = p->inventory[i+1];
            }
            p->inventoryCount--;
        }
    }
}

void gainExp(Player *p, int exp) {
    p->exp += exp;
    printf("📈 Gained %d EXP!\n", exp);
    
    while (p->exp >= p->expToNext) {
        p->exp -= p->expToNext;
        levelUp(p);
    }
}

void levelUp(Player *p) {
    p->level++;
    p->maxHp += classTemplates[p->class].hpBonus;
    p->maxMp += classTemplates[p->class].mpBonus;
    p->attack += 3;
    p->defense += 2;
    p->magic += 2;
    p->speed += 1;
    p->expToNext = (int)(p->expToNext * 1.2);
    
    p->hp = p->maxHp;
    p->mp = p->maxMp;
    
    printf("\n🎉 LEVEL UP! Now Level %d! 🎉\n", p->level);
    printf("HP: %d | MP: %d | ATK: %d | DEF: %d | MAG: %d\n",
           p->maxHp, p->maxMp, p->attack, p->defense, p->magic);
}

