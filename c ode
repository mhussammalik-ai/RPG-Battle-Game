#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define SAVE_FILE "savegame.dat"

#define MAX_NAME 30

// ---------------- PLAYER STRUCT ----------------
typedef struct {
    char name[MAX_NAME];
    int level;
    int hp;
    int max_hp;
    int mp;
    int max_mp;
    int attack;
    int defense;
    int exp;
    int gold;
} Player;

// ---------------- ENEMY STRUCT ----------------
typedef struct {
    char name[MAX_NAME];
    int hp;
    int attack;
    int defense;
    int exp_reward;
    int gold_reward;
    int is_boss;
} Enemy;

// ---------------- FUNCTION PROTOTYPES ----------------
void initPlayer(Player *p);
void saveGame(Player *p);
int loadGame(Player *p);
Enemy generateEnemy(Player *p);
void battle(Player *p);
void shop(Player *p);
void levelUp(Player *p);
int damageCalc(int atk, int def);
void skills(Player *p, Enemy *e);

// ---------------- MAIN ----------------
int main() {
    srand(time(NULL));

    Player player;

    printf("=== RPG BATTLE GAME ===\n");

    if (!loadGame(&player)) {
        initPlayer(&player);
        printf("Enter your name: ");
        scanf("%s", player.name);
    }

    int choice;

    while (1) {
        printf("\n===== MAIN MENU =====\n");
        printf("1. Battle\n");
        printf("2. Shop\n");
        printf("3. Save Game\n");
        printf("4. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                battle(&player);
                break;
            case 2:
                shop(&player);
                break;
            case 3:
                saveGame(&player);
                printf("Game Saved!\n");
                break;
            case 4:
                saveGame(&player);
                printf("Exiting Game...\n");
                exit(0);
        }
    }
}

// ---------------- INIT PLAYER ----------------
void initPlayer(Player *p) {
    p->level = 1;
    p->hp = 100;
    p->max_hp = 100;
    p->mp = 50;
    p->max_mp = 50;
    p->attack = 15;
    p->defense = 5;
    p->exp = 0;
    p->gold = 50;
}

// ---------------- SAVE GAME ----------------
void saveGame(Player *p) {
    FILE *fp = fopen(SAVE_FILE, "wb");
    fwrite(p, sizeof(Player), 1, fp);
    fclose(fp);
}

// ---------------- LOAD GAME ----------------
int loadGame(Player *p) {
    FILE *fp = fopen(SAVE_FILE, "rb");
    if (!fp) return 0;

    fread(p, sizeof(Player), 1, fp);
    fclose(fp);

    printf("Save Loaded!\n");
    return 1;
}

// ---------------- DAMAGE CALC ----------------
int damageCalc(int atk, int def) {
    int dmg = atk - def;
    if (dmg < 0) dmg = 0;
    return dmg + (rand() % 5);
}

// ---------------- LEVEL UP ----------------
void levelUp(Player *p) {
    while (p->exp >= 100) {
        p->exp -= 100;
        p->level++;

        p->max_hp += 20;
        p->max_mp += 10;
        p->attack += 5;
        p->defense += 3;

        p->hp = p->max_hp;
        p->mp = p->max_mp;

        printf("\n🎉 LEVEL UP! You are now Level %d\n", p->level);
    }
}

// ---------------- GENERATE ENEMY ----------------
Enemy generateEnemy(Player *p) {
    Enemy e;

    int bossChance = rand() % 10;

    if (p->level % 5 == 0 && bossChance < 3) {
        strcpy(e.name, "BOSS DRAGON");
        e.hp = 200 + p->level * 20;
        e.attack = 25 + p->level * 3;
        e.defense = 10 + p->level;
        e.exp_reward = 80;
        e.gold_reward = 100;
        e.is_boss = 1;
    } else {
        strcpy(e.name, "Enemy");
        e.hp = 60 + p->level * 10;
        e.attack = 10 + p->level * 2;
        e.defense = 5 + p->level;
        e.exp_reward = 40;
        e.gold_reward = 50;
        e.is_boss = 0;
    }

    return e;
}

// ---------------- SKILLS ----------------
void skills(Player *p, Enemy *e) {
    int choice;

    printf("\nSkills:\n");
    printf("1. Fireball (10 MP)\n");
    printf("2. Heal (8 MP)\n");
    printf("3. Power Strike (5 MP)\n");
    printf("4. Thunder (15 MP)\n");
    printf("Choose: ");
    scanf("%d", &choice);

    switch (choice) {
        case 1:
            if (p->mp >= 10) {
                int dmg = 30 + p->attack;
                e->hp -= dmg;
                p->mp -= 10;
                printf("Fireball deals %d damage!\n", dmg);
            }
            break;

        case 2:
            if (p->mp >= 8) {
                int heal = 40;
                p->hp += heal;
                if (p->hp > p->max_hp) p->hp = p->max_hp;
                p->mp -= 8;
                printf("Healed %d HP!\n", heal);
            }
            break;

        case 3:
            if (p->mp >= 5) {
                int dmg = 20 + p->attack * 2;
                e->hp -= dmg;
                p->mp -= 5;
                printf("Power Strike deals %d damage!\n", dmg);
            }
            break;

        case 4:
            if (p->mp >= 15) {
                int dmg = 50 + rand() % 30;
                e->hp -= dmg;
                p->mp -= 15;
                printf("Thunder hits for %d damage!\n", dmg);
            }
            break;
    }
}

// ---------------- BATTLE SYSTEM ----------------
void battle(Player *p) {
    Enemy e = generateEnemy(p);

    printf("\n⚔ Battle Started: %s appeared!\n", e.name);

    while (e.hp > 0 && p->hp > 0) {

        printf("\nYour HP: %d | MP: %d\n", p->hp, p->mp);
        printf("%s HP: %d\n", e.name, e.hp);

        int choice;
        printf("\n1. Attack\n2. Skill\n3. Flee\nChoice: ");
        scanf("%d", &choice);

        if (choice == 1) {
            int dmg = damageCalc(p->attack, e.defense);
            e.hp -= dmg;
            printf("You deal %d damage!\n", dmg);
        }

        else if (choice == 2) {
            skills(p, &e);
        }

        else if (choice == 3) {
            if (rand() % 2 == 0) {
                printf("You escaped!\n");
                return;
            } else {
                printf("Escape failed!\n");
            }
        }

        if (e.hp > 0) {
            int dmg = damageCalc(e.attack, p->defense);
            p->hp -= dmg;
            printf("%s deals %d damage!\n", e.name, dmg);
        }
    }

    if (p->hp <= 0) {
        printf("\n💀 You Died!\n");
        p->hp = p->max_hp;
        p->gold /= 2;
        return;
    }

    printf("\n🏆 Enemy defeated!\n");

    p->exp += e.exp_reward;
    p->gold += e.gold_reward;

    printf("Gained %d EXP and %d Gold\n", e.exp_reward, e.gold_reward);

    levelUp(p);
}

// ---------------- SHOP SYSTEM ----------------
void shop(Player *p) {
    int choice;

    printf("\n🏪 SHOP\n");
    printf("Gold: %d\n", p->gold);
    printf("1. Health Potion (20)\n");
    printf("2. Mana Potion (20)\n");
    printf("3. Upgrade Attack (50)\n");
    printf("4. Upgrade Defense (50)\n");
    printf("Choice: ");
    scanf("%d", &choice);

    if (choice == 1 && p->gold >= 20) {
        p->hp = p->max_hp;
        p->gold -= 20;
        printf("HP Restored!\n");
    }

    else if (choice == 2 && p->gold >= 20) {
        p->mp = p->max_mp;
        p->gold -= 20;
        printf("MP Restored!\n");
    }

    else if (choice == 3 && p->gold >= 50) {
        p->attack += 5;
        p->gold -= 50;
        printf("Attack Increased!\n");
    }

    else if (choice == 4 && p->gold >= 50) {
        p->defense += 5;
        p->gold -= 50;
        printf("Defense Increased!\n");
    }
}
