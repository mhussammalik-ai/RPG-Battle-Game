// ---------------- COMBAT ----------------
void playerTurn(struct Player *p, struct Enemy *e) {
    int choice;
    static int defending = 0;
    
    printf("\nYour action: ");
    scanf("%d", &choice);
    clearInputBuffer();
    
    switch (choice) {
        case 1: { // Attack
            int damage = (rand() % 15) + p->attack - (e->defense / 2);
            if (damage < 5) damage = 5;
            
            // Critical Hit (20% chance)
            if (rand() % 5 == 0) {
                damage *= 2;
                printf("🎯 CRITICAL HIT! ");
            }
            
            e->hp -= damage;
            printf("⚔ You attacked! Dealt %d damage!\n", damage);
            break;
        }
        
        case 2: { // Skills
            castSkill(p, e);
            break;
        }
        
        case 3: { // Use Item
            useItem(p, e);
            break;
        }
        
        case 4: { // Defend
            printf("🛡 You take a defensive stance! Damage reduced by 50%% this turn!\n");
            defending = 1;
            break;
        }
        
        case 5: { // Flee
            if (rand() % 2 == 0) {
                printf("🏃 You successfully fled!\n");
                // Exit battle completely
                return;
            } else {
                printf("😰 Failed to flee!\n");
            }
            break;
        }
        
        default:
            printf("Invalid choice!\n");
    }
    
    if (e->hp < 0) e->hp = 0;
    
    // Store defend state for enemy turn (use a static variable or pass it)
    // For now, we'll handle it in enemyTurn
}

void castSkill(struct Player *p, struct Enemy *e) {
    int choice;
    
    displaySkills(*p);
    printf("Select skill: ");
    scanf("%d", &choice);
    clearInputBuffer();
    
    if (choice == 0) return;
    if (choice < 1 || choice > p->skillCount) {
        printf("Invalid skill choice!\n");
        return;
    }
    
    choice--; // Adjust to 0-based index
    struct Skill *skill = &p->skills[choice];
    
    if (p->mp < skill->mpCost) {
        printf("❌ Not enough MP! Need %d MP (You have %d)\n", skill->mpCost, p->mp);
        return;
    }
    
    p->mp -= skill->mpCost;
    
    if (skill->minDamage < 0) { // Healing skill
        int healAmount = -skill->minDamage;
        p->hp += healAmount;
        if (p->hp > p->maxHp) p->hp = p->maxHp;
        printf("💚 %s restored %d HP! (HP: %d/%d)\n", skill->name, healAmount, p->hp, p->maxHp);
    } else {
        int damage = (rand() % (skill->maxDamage - skill->minDamage + 1)) + skill->minDamage;
        damage -= (e->defense / 3);
        if (damage < 10) damage = 10;
        
        e->hp -= damage;
        printf("✨ %s dealt %d damage to %s! ✨\n", skill->name, damage, e->name);
    }
}

void useItem(struct Player *p, struct Enemy *e) {
    int choice;
    
    printf("\n📦 INVENTORY:\n");
    printf("1. Health Potion (+40 HP) - %d left\n", p->inventory[0].quantity);
    printf("2. Mana Potion (+30 MP) - %d left\n", p->inventory[1].quantity);
    printf("3. Elixir (Full HP/MP) - %d left\n", p->elixirs);
    printf("0. Cancel\n");
    printf("Choose: ");
    scanf("%d", &choice);
    clearInputBuffer();
    
    switch (choice) {
        case 1:
            if (p->inventory[0].quantity > 0) {
                p->hp += 40;
                if (p->hp > p->maxHp) p->hp = p->maxHp;
                p->inventory[0].quantity--;
                printf("💊 Used Health Potion! HP: %d/%d\n", p->hp, p->maxHp);
            } else {
                printf("❌ No Health Potions left!\n");
            }
            break;
            
        case 2:
            if (p->inventory[1].quantity > 0) {
                p->mp += 30;
                if (p->mp > p->maxMp) p->mp = p->maxMp;
                p->inventory[1].quantity--;
                printf("🔮 Used Mana Potion! MP: %d/%d\n", p->mp, p->maxMp);
            } else {
                printf("❌ No Mana Potions left!\n");
            }
            break;
            
        case 3:
            if (p->elixirs > 0) {
                p->hp = p->maxHp;
                p->mp = p->maxMp;
                p->elixirs--;
                printf("🌟 Used Elixir! Fully restored! 🌟\n");
            } else {
                printf("❌ No Elixirs left!\n");
            }
            break;
            
        case 0:
            printf("Cancelled.\n");
            break;
            
        default:
            printf("Invalid choice!\n");
    }
}

void enemyTurn(struct Player *p, struct Enemy *e) {
    printf("\n💀 %s's turn... 💀\n", e->name);
    
    int action = rand() % 100;
    int damage;
    static int playerDefending = 0;
    
    // Simple defend flag - in a real implementation, this would be passed
    // For now, we'll assume player isn't defending (fix this properly)
    playerDefending = 0;
    
    if (e->type == 3) { // Boss AI
        if (action < 30) {
            damage = rand() % 25 + e->attack;
            printf("🔥 %s uses FLAME BREATH! ", e->name);
        } else if (action < 60) {
            damage = rand() % 20 + e->attack;
            printf("⚡ %s uses THUNDER STRIKE! ", e->name);
        } else {
            damage = rand() % 15 + e->attack;
            printf("👊 %s attacks! ", e->name);
        }
    } else if (e->type == 2) { // Elite AI
        if (action < 40) {
            damage = rand() % 20 + e->attack;
            printf("⚡ %s uses POWER ATTACK! ", e->name);
        } else {
            damage = rand() % 12 + e->attack;
            printf("👊 %s attacks! ", e->name);
        }
    } else { // Normal AI
        damage = rand() % 10 + e->attack;
        printf("👊 %s attacks! ", e->name);
    }
    
    // Reduce damage if player is defending
    if (playerDefending) {
        damage = damage / 2;
        printf("(Reduced due to defense!) ");
    }
    
    // Apply player defense reduction
    damage -= (p->defense / 3);
    if (damage < 3) damage = 3;
    
    p->hp -= damage;
    if (p->hp < 0) p->hp = 0;
    printf("Dealt %d damage! 💔\n", damage);
}

// ---------------- PROGRESSION ----------------
void gainExp(struct Player *p, int exp) {
    p->exp += exp;
    printf("📈 Gained %d EXP! 📈\n", exp);
    
    while (p->exp >= p->expToNext) {
        p->exp -= p->expToNext;
        levelUp(p);
    }
}

void levelUp(struct Player *p) {
    p->level++;
    p->maxHp += 20;
    p->maxMp += 15;
    p->attack += 5;
    p->defense += 3;
    p->expToNext = (int)(p->expToNext * 1.2);
    if (p->expToNext < 100) p->expToNext = 100;
    
    // Full restore on level up
    p->hp = p->maxHp;
    p->mp = p->maxMp;
    
    printf("\n🎉🎉🎉 LEVEL UP! Now Level %d! 🎉🎉🎉\n", p->level);
    printf("❤️ HP: %d -> %d\n", p->maxHp - 20, p->maxHp);
    printf("💙 MP: %d -> %d\n", p->maxMp - 15, p->maxMp);
    printf("⚔ Attack: %d -> %d\n", p->attack - 5, p->attack);
    printf("🛡 Defense: %d -> %d\n", p->defense - 3, p->defense);
    
    // Bonus items on level up
    if (p->level % 3 == 0) {
        p->inventory[0].quantity++;
        printf("🎁 Bonus: Health Potion x1 added to inventory!\n");
    }
}

int checkGameOver(struct Player p) {
    if (p.hp <= 0) {
        printf("\n💀💀💀 %s has been defeated! 💀💀💀\n", p.name);
        return 1;
    }
    return 0;
}

// ---------------- ENEMY GENERATION ----------------
void generateEnemy(struct Player p, struct Enemy *e) {
    const char *normalNames[] = {"Goblin", "Wolf", "Orc", "Skeleton", "Bandit", "Dark Mage"};
    const char *eliteNames[] = {"Ogre", "Troll", "Dark Knight", "Vampire", "Demon"};
    const char *bossNames[] = {"Dragon", "Lich King", "Demon Lord", "Ancient Titan", "Void Walker"};
    
    int random = rand() % 100;
    
    // Boss every 5 levels, Elite sometimes in between
    if (p.level % 5 == 0) {
        e->type = 3;
        strcpy(e->name, bossNames[rand() % 5]);
        e->maxHp = 150 + (p.level * 15);
        e->attack = 20 + (p.level * 3);
        e->defense = 10 + (p.level * 2);
        e->expReward = 200 + (p.level * 20);
        e->goldReward = 150 + (p.level * 15);
        printf("\n👑👑👑 BOSS ENCOUNTER: %s! 👑👑👑\n", e->name);
    } else if (random < 20) { // 20% chance for elite
        e->type = 2;
        strcpy(e->name, eliteNames[rand() % 5]);
        e->maxHp = 80 + (p.level * 12);
        e->attack = 15 + (p.level * 2);
        e->defense = 8 + (p.level * 1);
        e->expReward = 80 + (p.level * 10);
        e->goldReward = 60 + (p.level * 8);
        printf("\n⚔ Elite Enemy: %s appears! ⚔\n", e->name);
    } else {
        e->type = 1;
        strcpy(e->name, normalNames[rand() % 6]);
        e->maxHp = 50 + (p.level * 8);
        e->attack = 10 + (p.level * 1);
        e->defense = 5 + (p.level * 1);
        e->expReward = 40 + (p.level * 5);
        e->goldReward = 30 + (p.level * 4);
        printf("\n👾 %s appears! 👾\n", e->name);
    }
    
    e->hp = e->maxHp;
}

