                p->gold -= 25;
                printf("Purchased!\n");
            }
            break;
        case 3:
            if (p->gold >= 80) {
                p->attack += 5;
                p->gold -= 80;
                printf("ATK increased to %d!\n", p->attack);
            }
            break;
        case 4:
            if (p->gold >= 80) {
                p->defense += 5;
