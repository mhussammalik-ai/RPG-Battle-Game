void blacksmith(Player *p) {
    int choice;
    printf("\n⚒️ BLACKSMITH ⚒️\n");
    printf("Gold: %d\n\n", p->gold);
    printf("Current Weapon: %s (%s)\n", p->weapon.name, p->weapon.rarity);
    printf("Current Armor: %s (%s)\n\n", p->armor.name, p->armor.rarity);
    
    printf("Available Upgrades:\n");
    printf("1. Upgrade Weapon - %d gold\n", 200 * p->level);
    printf("2. Upgrade Armor  - %d gold\n", 150 * p->level);
    printf("3. Craft Item     - 100 gold\n");
    printf("0. Leave\nChoice: ");
    scanf("%d", &choice);
    
    switch(choice) {
        case 1:
            if (p->gold >= 200 * p->level) {
                p->weapon.minDamage += 5;
                p->weapon.maxDamage += 10;
                p->gold -= 200 * p->level;
                printf("Weapon upgraded! %s now deals %d-%d damage\n",
                       p->weapon.name, p->weapon.minDamage, p->weapon.maxDamage);
            } else {
                printf("Not enough gold!\n");
            }
            break;
        case 2:
            if (p->gold >= 150 * p->level) {
                p->armor.defense += 3;
                p->gold -= 150 * p->level;
                printf("Armor upgraded! Defense: %d\n", p->armor.defense);
            } else {
                printf("Not enough gold!\n");
            }
            break;
        case 3:
            craftItem(p);
            break;
    }
}

void craftItem(Player *p) {
    printf("\n🔨 CRAFTING 🔨\n");
    printf("1. Health Potion (50g)\n");
    printf("2. Mana Potion (40g)\n");
    printf("3. Bomb (80g) - Deals 50 damage to enemy\n");
    printf("Choice: ");
    
    int choice;
    scanf("%d", &choice);
    
    int cost = 0;
    char itemName[30];
    int effect = 0;
    
    switch(choice) {
        case 1:
            cost = 50;
            strcpy(itemName, "Health Potion");
            effect = 50;
            break;
        case 2:
            cost = 40;
            strcpy(itemName, "Mana Potion");
            effect = 30;
            break;
        case 3:
            cost = 80;
            strcpy(itemName, "Bomb");
            effect = 50;
            break;
        default:
            return;
    }
    
    if (p->gold >= cost) {
        Item newItem = {itemName, effect, 1, 99, choice == 3 ? "bomb" : (choice == 1 ? "healing" : "mana")};
        p->inventory[p->inventoryCount++] = newItem;
        p->gold -= cost;
        printf("Crafted %s!\n", itemName);
    } else {
        printf("Not enough gold!\n");
    }
}

void questGiver(Player *p, Quest *quests) {
    printf("\n❓ QUEST BOARD ❓\n");
    for (int i = 0; i < MAX_QUESTS; i++) {
        if (quests[i].status != QUEST_COMPLETED) {
            printf("%d. %s - %s (%d/%d)\n", i+1, quests[i].name, 
                   quests[i].description, quests[i].currentProgress, quests[i].requiredProgress);
            if (quests[i].currentProgress >= quests[i].requiredProgress) {
                quests[i].status = QUEST_COMPLETED;
                printf("   ✅ QUEST COMPLETED! Claim reward\n");
            }
        }
    }
    
    for (int i = 0; i < MAX_QUESTS; i++) {
        if (quests[i].status == QUEST_COMPLETED) {
            printf("\nClaim reward for %s? (1=Yes): ", quests[i].name);
            int claim;
            scanf("%d", &claim);
            if (claim == 1) {
                p->exp += quests[i].rewardExp;
                p->gold += quests[i].rewardGold;
                printf("Reward: %d EXP, %d Gold\n", quests[i].rewardExp, quests[i].rewardGold);
                quests[i].status = QUEST_FAILED; // Mark as claimed
            }
        }
    }
}

