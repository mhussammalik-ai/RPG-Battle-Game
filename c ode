#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define MAX_NAME 30

// ================= PLAYER =================
typedef struct {
    char name[MAX_NAME];

    int level;
    int hp, max_hp;
    int mp, max_mp;
    int attack;
    int defense;
    int exp;
    int gold;

    int kills;
    int damageDealt;
    int damageTaken;
} Player;

// ================= ENEMY =================
typedef struct {
    char name[40];
    int hp;
    int attack;
    int defense;
    int exp;
    int gold;
    int isBoss;
} Enemy;

// ================= RANDOM =================
int r(int a, int b) {
    return a + rand() % (b - a + 1);
}

// ================= RULES =================
void showRules() {
    printf("\n========== GAME RULES ==========\n");
    printf("1. Choose map first\n");
    printf("2. Fight enemies & bosses\n");
    printf("3. Every 100 EXP = Level Up\n");
    printf("4. Boss every 5 levels\n");
    printf("5. Skills use MP\n");
    printf("6. HP = 0 → Game Over\n");
    printf("================================\n");
}

// ================= MAP =================
int chooseMap() {
    int m;

    printf("\n========== MAP SELECT ==========\n");
    printf("1. Forest 🌲\n");
    printf("2. Dungeon 🏰\n");
    printf("3. Dark Zone 🌑\n");
    printf("4. Chaos World 🔥\n");
    printf("Choose: ");
    scanf("%d", &m);

    if (m < 1 || m > 4) m = 1;

    printf("\n🌍 Selected Map: %d\n", m);

    return m;
}

// ================= INIT =================
void init(Player *p) {
    p->level = 1;
    p->hp = p->max_hp = 120;
    p->mp = p->max_mp = 60;
    p->attack = 15;
    p->defense = 5;
    p->exp = 0;
    p->gold = 50;

    p->kills = 0;
    p->damageDealt = 0;
    p->damageTaken = 0;
}

// ================= LEVEL UP =================
void levelUp(Player *p) {
    while (p->exp >= 100) {
        p->exp -= 100;
        p->level++;

        p->max_hp += 25;
        p->max_mp += 10;
        p->attack += 5;
        p->defense += 3;

        p->hp = p->max_hp;
        p->mp = p->max_mp;

        printf("\n🔥 LEVEL UP → Level %d 🔥\n", p->level);

        if (p->level % 5 == 0) {
            printf("👑 BOSS LEVEL REACHED!\n");
        }
    }
}

// ================= ENEMY SYSTEM =================
Enemy createEnemy(Player *p, int map) {
    Enemy e;

    if (p->level % 5 == 0) {
        e.isBoss = 1;

        if (map == 1) sprintf(e.name, "Forest King Thornroot");
        else if (map == 2) sprintf(e.name, "Skeleton King Xerath");
        else if (map == 3) sprintf(e.name, "Shadow Emperor Nocturn");
        else sprintf(e.name, "Chaos Titan Zorath");

        e.hp = 200 + p->level * 30;
        e.attack = 25 + p->level * 4;
        e.defense = 10 + p->level;
        e.exp = 90;
        e.gold = 150;
    } else {
        e.isBoss = 0;

        char *forest[] = {"Wolf", "Vine Stalker", "Forest Hunter", "Root Beast"};
        char *dungeon[] = {"Skeleton Knight", "Cursed Armor", "Dark Prisoner", "Blood Warden"};
        char *dark[] = {"Void Walker", "Shadow Reaper", "Nightmare", "Soul Devourer"};
        char *chaos[] = {"Flame Demon", "Chaos Beast", "Rift Walker", "Infernal Shade"};

        int pick = r(0,3);

        if (map == 1) sprintf(e.name, "%s", forest[pick]);
        else if (map == 2) sprintf(e.name, "%s", dungeon[pick]);
        else if (map == 3) sprintf(e.name, "%s", dark[pick]);
        else sprintf(e.name, "%s", chaos[pick]);

        e.hp = 60 + p->level * 10;
        e.attack = 10 + p->level * 2;
        e.defense = 5 + p->level;
        e.exp = 40;
        e.gold = 50;
    }

    return e;
}

// ================= DAMAGE =================
int dmg(int a, int d) {
    int x = a - d;
    if (x < 0) x = 0;
    return x + r(0,5);
}

// ================= BATTLE =================
int battle(Player *p, int map) {
    Enemy e = createEnemy(p, map);

    printf("\n⚔ ENEMY → %s APPEARED!\n", e.name);

    while (e.hp > 0 && p->hp > 0) {

        printf("\n==============================\n");
        printf("HP: %d/%d | MP: %d/%d\n", p->hp, p->max_hp, p->mp, p->max_mp);
        printf("Enemy HP: %d\n", e.hp);
        printf("==============================\n");

        int c;

        printf("\n1.Attack ⚔\n");
        printf("2.Skill 🔥\n");
        printf("3.Flee 🏃\n");
        printf("Choice: ");
        scanf("%d", &c);

        // ATTACK
        if (c == 1) {
            int d = dmg(p->attack, e.defense);
            e.hp -= d;
            p->damageDealt += d;
            printf("⚔ You dealt %d damage!\n", d);
        }

        // SKILL
        else if (c == 2) {

            int s;
            printf("\n🔥 SKILLS:\n");
            printf("1.Fireball (10 MP)\n");
            printf("2.Thunder (15 MP)\n");
            printf("3.Heal (8 MP)\n");
            printf("Choose: ");
            scanf("%d", &s);

            if (s == 1 && p->mp >= 10) {
                int d = 40 + p->attack;
                e.hp -= d;
                p->mp -= 10;
                printf("🔥 Fireball %d damage!\n", d);
            }
            else if (s == 2 && p->mp >= 15) {
                int d = 65 + r(0,20);
                e.hp -= d;
                p->mp -= 15;
                printf("⚡ Thunder %d damage!\n", d);
            }
            else if (s == 3 && p->mp >= 8) {
                int h = 40;
                p->hp += h;
                if (p->hp > p->max_hp) p->hp = p->max_hp;
                p->mp -= 8;
                printf("💚 Heal +%d HP!\n", h);
            }
            else {
                printf("❌ Not enough MP or invalid skill!\n");
            }
        }

        // FLEE
        else if (c == 3) {
            if (r(0,1)) {
                printf("🏃 Escape successful!\n");
                return 0;
            } else {
                printf("❌ Escape failed!\n");
            }
        }

        else {
            printf("❌ Invalid choice!\n");
        }

        // ENEMY TURN
        if (e.hp > 0) {
            int d = dmg(e.attack, p->defense);
            p->hp -= d;
            p->damageTaken += d;
            printf("💀 Enemy hits %d damage!\n", d);
        }
    }

    // WIN / LOSE
    if (p->hp <= 0) return 0;

    printf("\n🏆 %s DEFEATED!\n", e.name);

    p->kills++;
    p->exp += e.exp;
    p->gold += e.gold;

    levelUp(p);

    if (p->level % 5 == 0) {
        printf("🎉 BOSS CLEARED! AMAZING!\n");
    }

    return 1;
}

// ================= STATS =================
void showStats(Player *p) {
    printf("\n========== FINAL STATS ==========\n");
    printf("Name: %s\n", p->name);
    printf("Level: %d\n", p->level);
    printf("Kills: %d\n", p->kills);
    printf("Gold: %d\n", p->gold);
    printf("Damage Dealt: %d\n", p->damageDealt);
    printf("Damage Taken: %d\n", p->damageTaken);
    printf("================================\n");
}

// ================= MAIN =================
int main() {
    srand(time(NULL));

    Player p;

    printf("=================================\n");
    printf("      🎮 STARZILLA RPG 🎮\n");
    printf("=================================\n");

    showRules();

    int map = chooseMap();

    printf("\nEnter Player Name: ");
    scanf("%s", p.name);

    init(&p);

    printf("\n👤 Welcome %s!\n", p.name);

    while (1) {

        int c;
        printf("\n===== MENU =====\n");
        printf("1. Battle ⚔\n");
        printf("2. Exit 🚪\n");
        printf("Choice: ");
        scanf("%d", &c);

        if (c == 1) {
            int res = battle(&p, map);

            if (res == 0) {
                printf("\n☠ GAME OVER ☠\n");
                printf("💬 Thank you for playing!\n");
                showStats(&p);
                break;
            }
        }
        else if (c == 2) {
            printf("\n👋 Goodbye!\n");
            showStats(&p);
            break;
        }
        else {
            printf("❌ Invalid input!\n");
        }
    }

    return 0;
}
