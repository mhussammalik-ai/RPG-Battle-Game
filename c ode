void enterDungeon(Player *p) {
    static int currentFloor = 1;
    Enemy boss;
    
    printf("\n🏰 DUNGEON CRAWL 🏰\n");
    printf("Current Floor: %d\n", currentFloor);
    printf("1. Continue to next floor\n");
    printf("2. Return to town\n");
    printf("Choice: ");
    
    int choice;
    scanf("%d", &choice);
    
    if (choice == 2) {
        currentFloor = 1;
        return;
    }
    
    printf("\nEntering Floor %d...\n", currentFloor);
    
    // Generate enemies for this floor
    int enemiesToFight = (currentFloor / 5) + 1;
    if (enemiesToFight > 3) enemiesToFight = 3;
    
    for (int i = 0; i < enemiesToFight; i++) {
        Enemy enemy;
        generateEnemy(*p, &enemy, currentFloor);
        battle(p, &enemy);
        if (p->hp <= 0) {
            currentFloor = 1;
            return;
        }
    }
    
    // Boss every 5 floors
    if (currentFloor % 5 == 0) {
        printf("\n⚠️ FLOOR %d BOSS ENCOUNTER! ⚠️\n", currentFloor);
        generateEnemy(*p, &boss, currentFloor);
        battle(p, &boss);
        if (p->hp > 0) {
            printf("🎉 FLOOR %d CLEARED! 🎉\n", currentFloor);
            p->score += 500;
        } else {
            currentFloor = 1;
            return;
        }
    }
    
    currentFloor++;
    printf("Proceeding to next floor...\n");
}

void arena(Player *p) {
    printf("\n🏟️ ARENA MODE 🏟️\n");
    printf("Fight consecutive battles for rewards!\n");
    printf("Entry Fee: 100 gold\n");
    
    if (p->gold < 100) {
        printf("Not enough gold!\n");
        return;
    }
    
    p->gold -= 100;
    int wins = 0;
    
    for (int round = 1; round <= 5; round++) {
        printf("\n=== ARENA ROUND %d ===\n", round);
        Enemy enemy;
        generateEnemy(*p, &enemy, round);
        battle(p, &enemy);
        
        if (p->hp <= 0) {
            printf("Arena run ends at round %d!\n", round);
            break;
        }
        
        wins++;
    }
    
    int reward = wins * 200;
    p->gold += reward;
    printf("\nArena Complete! %d wins!\n", wins);
    printf("Reward: %d gold\n", reward);
}

