void applyStatusEffect(Player *p, StatusEffect effect, int duration) {
    p->activeEffect = effect;
    p->effectDuration = duration;
    
    switch(effect) {
        case EFFECT_POISON:
            printf("You've been poisoned!\n");
            break;
        case EFFECT_BURN:
            printf("You're on fire!\n");
            break;
        case EFFECT_FREEZE:
            printf("You're frozen! Speed reduced!\n");
            p->speed /= 2;
            break;
        case EFFECT_STUN:
            printf("You're stunned!\n");
            break;
        default:
            break;
    }
}

void updateWorldTime(WorldTime *wt) {
    wt->minute += 10;
    if (wt->minute >= 60) {
        wt->minute = 0;
        wt->hour++;
        if (wt->hour >= 24) {
            wt->hour = 0;
            wt->day++;
        }
    }
    
    // Weather change
    if (rand() % 100 < 5) {
        const char *weathers[] = {"Sunny", "Rainy", "Stormy", "Snowy"};
        strcpy(wt->weather, weathers[rand() % 4]);
    }
}

void displayWorldInfo(WorldTime wt) {
    printf("\n📅 Day %d | %02d:%02d | %s ☁️\n", 
           wt.day, wt.hour, wt.minute, wt.weather);
}

void saveGame(Player p, int slot) {
    char filename[20];
    sprintf(filename, "save%d.dat", slot);
    FILE *file = fopen(filename, "wb");
    if (file) {
        fwrite(&p, sizeof(Player), 1, file);
        fclose(file);
        printf("Game saved to slot %d!\n", slot);
    } else {
        printf("Save failed!\n");
    }
}

int loadGame(Player *p, int slot) {
    char filename[20];
    sprintf(filename, "save%d.dat", slot);
    FILE *file = fopen(filename, "rb");
    if (file) {
        fread(p, sizeof(Player), 1, file);
        fclose(file);
        return 1;
    }
    return 0;
}

