void initGame(Player *p) {
    printf("Enter your hero's name: ");
    scanf("%s", p->name);
    
    selectClass(p);
    
    p->hp = p->maxHp = 100 + classTemplates[p->class].hpBonus;
    p->mp = p->maxMp = 50 + classTemplates[p->class].mpBonus;
    p->attack = 10 + classTemplates[p->class].attackBonus;
    p->defense = 5 + classTemplates[p->class].defenseBonus;
    p->magic = 5 + classTemplates[p->class].magicBonus;
    p->speed = 5 + classTemplates[p->class].speedBonus;
    p->level = 1;
    p->exp = 0;
    p->expToNext = 100;
    p->score = 0;
    p->gold = 100;
    p->kills = 0;
    p->critChance = 5;
    p->dodgeChance = 5;
    p->activeEffect = -1;
    p->effectDuration = 0;
    p->inventoryCount = 0;
    
    initEquipment(p);
    initSkills(p, p->class);
    
    // Starting items
    Item healthPotion = {"Health Potion", 50, 3, 99, "healing"};
    Item manaPotion = {"Mana Potion", 30, 2, 99, "mana"};
    p->inventory[p->inventoryCount++] = healthPotion;
    p->inventory[p->inventoryCount++] = manaPotion;
}

