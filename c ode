        case 1:
            if (p->gold >= 30) {
                Item potion = {"Health Potion", 50, 1, 99, "healing"};
                p->inventory[p->inventoryCount++] = potion;
                p->gold -= 30;
                printf("Purchased!\n");
            }
            break;
        case 2:
            if (p->gold >= 25) {
                Item potion = {"Mana Potion", 30, 1, 99, "mana"};
