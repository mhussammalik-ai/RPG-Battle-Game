#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <string.h>

// ---------------- CONSTANTS ----------------
#define MAX_NAME_LEN 20
#define MAX_INVENTORY 10
#define MAX_SKILLS 4

// ---------------- STRUCTURES ----------------

struct Item {
    char name[20];
    int effect;
    int quantity;
};

struct Skill {
    char name[20];
    int mpCost;
    int minDamage;
    int maxDamage;
    char description[50];
};

struct Player {
    char name[MAX_NAME_LEN];
    int hp;
    int maxHp;
    int mp;
    int maxMp;
    int attack;
    int defense;
    int level;
    int exp;
    int expToNext;
    int score;
    int gold;
    int potions;  // Keep for backward compatibility
    int elixirs;
    struct Item inventory[MAX_INVENTORY];
    struct Skill skills[MAX_SKILLS];
    int skillCount;
};

struct Enemy {
    char name[20];
    int hp;
    int maxHp;
    int attack;
    int defense;
    int type; // 1 = normal, 2 = elite, 3 = boss
    int expReward;
    int goldReward;
};

// ---------------- FUNCTION DECLARATIONS ----------------
void initGame(struct Player *p);
void initSkills(struct Player *p);
void displayStatus(struct Player p, struct Enemy e);
void displayBattleMenu(struct Player p);
void playerTurn(struct Player *p, struct Enemy *e);
void enemyTurn(struct Player *p, struct Enemy *e);
int checkGameOver(struct Player p);
void levelUp(struct Player *p);
void gainExp(struct Player *p, int exp);
void generateEnemy(struct Player p, struct Enemy *e);
void useItem(struct Player *p, struct Enemy *e);
void castSkill(struct Player *p, struct Enemy *e);
void shop(struct Player *p);
void saveGame(struct Player p);
int loadGame(struct Player *p);
void displayHelp();
void clearInputBuffer();

// ---------------- MAIN ----------------
int main() {
    struct Player player;
    struct Enemy enemy;
    int choice;
    int inBattle = 0;
    
    srand(time(0));
    
    printf("===== EPIC RPG BATTLE GAME =====\n");
    printf("1. New Game\n");
    printf("2. Load Game\n");
    printf("Choose: ");
    scanf("%d", &choice);
    clearInputBuffer();
    
    if (choice == 2 && loadGame(&player)) {
        printf("Game loaded successfully!\n");
    } else {
        initGame(&player);
    }
    
    generateEnemy(player, &enemy);
    
    printf("\nWelcome, %s! Your adventure begins now!\n", player.name);
    
    while (1) {
        if (!inBattle) {
            printf("\n--- WORLD MENU ---\n");
            printf("1. Fight Next Enemy\n");
            printf("2. Shop\n");
            printf("3. Save Game\n");
            printf("4. Help\n");
            printf("5. Quit Game\n");
            printf("Choose: ");
            scanf("%d", &choice);
            clearInputBuffer();
            
            switch(choice) {
                case 1:
                    inBattle = 1;
                    generateEnemy(player, &enemy);
                    break;
                case 2:
                    shop(&player);
                    continue;
                case 3:
                    saveGame(player);
                    continue;
                case 4:
                    displayHelp();
                    continue;
                case 5:
                    printf("Thanks for playing!\n");
                    return 0;
                default:
                    printf("Invalid choice!\n");
                    continue;
            }
        }
        
        // Battle loop
        while (inBattle) {
            displayStatus(player, enemy);
            displayBattleMenu(player);
            playerTurn(&player, &enemy);
            
            if (enemy.hp <= 0) {
                printf("\n✨ Victory! %s defeated! ✨\n", enemy.name);
                player.score += 10 * player.level;
                player.gold += enemy.goldReward;
                gainExp(&player, enemy.expReward);
                printf("💰 Gained %d gold! 💰\n", enemy.goldReward);
                inBattle = 0;
                break;
            }
            
            if (player.hp <= 0) {
                if (checkGameOver(player)) {
                    printf("\n💀 Game Over! Final Score: %d 💀\n", player.score);
                    return 0;
                }
                inBattle = 0;
                break;
            }
            
            enemyTurn(&player, &enemy);
            if (player.hp <= 0) {
                if (checkGameOver(player)) {
                    printf("\n💀 Game Over! Final Score: %d 💀\n", player.score);
                    return 0;
                }
                inBattle = 0;
                break;
            }
        }
    }
    
    return 0;
}

// ---------------- HELPER FUNCTIONS ----------------
void clearInputBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

