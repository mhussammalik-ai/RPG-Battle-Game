void comboSystem(int *combo, int damage) {
    if (damage > 30) {
        (*combo)++;
        if (*combo >= 3) {
            printf("🔥 %d HIT COMBO! 🔥\n", *combo);
        }
    } else {
        *combo = 0;
    }
}

void calculateCritical(Player p, int *damage) {
    if (rand() % 100 < p.critChance) {
        *damage *= 2;
        printf("💥 CRITICAL HIT! 💥\n");
    }
}
