/*
 * CODE QUEST RPG 
 */

#include <stdio.h>

void showStats(int health, int xp);
void askQuestion(int *health, int *xp, char level[], char question[], int correctAnswer, FILE *report);


void showStats(int health, int xp)
{
    printf("\nHealth: %d/100 | XP: %d/100\n", health, xp);
}


void askQuestion(int *health, int *xp, char level[], char question[], int correctAnswer, FILE *report)
{
    int userAnswer;

    printf("\n>>> %s <<<\n", level);
    printf("%s\n", question);
    printf("Your Answer: ");
    scanf("%d", &userAnswer);

    fprintf(report, "Level: %s\n", level);
    fprintf(report, "User Answer: %d | Correct Answer: %d\n", userAnswer, correctAnswer);

    if (userAnswer == correctAnswer)
    {
        *xp += 10;
        printf("[CORRECT!] +10 XP\n");
        fprintf(report, "Result: CORRECT (+10 XP)\n\n"); 
    }
    else
    {
        *health -= 10;
        printf("[WRONG!] -10 Health\n");
        printf("Correct Answer was: %d\n", correctAnswer);
        fprintf(report, "Result: WRONG (-10 Health)\n\n"); 
    }

    showStats(*health, *xp);
}


int main()
{
    int health = 100;
    int xp     = 0;

    FILE *reportFile = fopen("game_report.txt", "w");
    
    if (reportFile == NULL) {
        printf("Error: File nahi ban saki!\n");
        return 1;
    }

    fprintf(reportFile, " CODE QUEST RPG - PLAYER REPORT \n\n");

    
    printf("--- CODE QUEST RPG ---\n");
    printf("Welcome Young Programmer!\n");
    printf("Answer the questions correctly.\n");
    printf("Correct Answer = +10 XP\n");
    printf("Wrong Answer = -10 Health\n");
    printf("Health = 0 = GAME OVER\n");

    showStats(health, xp);

    
    askQuestion(&health, &xp, "LEVEL 1 : Variable Forest", "What is the value of x?\n int x = 5;", 5, reportFile);
    if (health <= 0) {
        printf("\nGAME OVER! Better luck next time.\n");
        fprintf(reportFile, "STATUS: GAME OVER\n");
        fclose(reportFile); 
