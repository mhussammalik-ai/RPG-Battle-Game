#include <stdio.h>

/* ----------- Function Prototypes ----------- */
void showStats(int health, int xp);
void askQuestion(int *health, int *xp, char level[], char question[], int correctAnswer);

/* ============================================================
   showStats()
   Purpose : Current health aur XP screen par dikhata hai
   ============================================================ */
void showStats(int health, int xp)
{
    printf("\n------------------------------------\n");
    printf("  Health : %d/100  |  XP : %d/100\n", health, xp);
    printf("------------------------------------\n");
}

/* ============================================================
   askQuestion()
   Purpose : Ek question poochta hai, answer check karta hai,
             aur health/xp ko update karta hai
   Parameters:
     health        - pointer to health variable
     xp            - pointer to xp variable
     level         - level ka naam (string)
     question      - question text (string)
     correctAnswer - sahi jawab (integer)
   ============================================================ */
void askQuestion(int *health, int *xp, char level[], char question[], int correctAnswer)
{
    int userAnswer;

    printf("\n====================================\n");
    printf("  %s\n", level);
    printf("====================================\n");
    printf("\n%s\n", question);
    printf("\nYour Answer : ");
    scanf("%d", &userAnswer);

    if (userAnswer == correctAnswer)
    {
        *xp += 10;
        printf("\n  [CORRECT!] +10 XP\n");
    }
    else
    {
        *health -= 10;
        printf("\n  [WRONG!] -10 Health\n");
        printf("  Correct Answer was : %d\n", correctAnswer);
    }

    showStats(*health, *xp);
}

/* ============================================================
   main()
   Purpose : Game ka pura flow control karta hai
   ============================================================ */
